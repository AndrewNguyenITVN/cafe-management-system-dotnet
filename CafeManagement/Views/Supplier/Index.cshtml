@model IEnumerable<CafeManagement.Models.Domain.Supplier>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Nhà cung cấp";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">🚚 Quản lý Nhà cung cấp</h4>
    <a asp-action="Create" class="btn btn-primary">+ Thêm nhà cung cấp</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tên nhà cung cấp</th>
                    <th>Điện thoại</th>
                    <th>Địa chỉ</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (supplier, i) in Model.Select((s, i) => (s, i + 1)))
                {
                    <tr>
                        <td>@i</td>
                        <td class="fw-semibold">@supplier.Name</td>
                        <td>@(supplier.Phone ?? "—")</td>
                        <td class="text-muted">@(supplier.Address ?? "—")</td>
                        <td>
                            <span class="badge @(supplier.IsActive ? "bg-success" : "bg-secondary")">
                                @(supplier.IsActive ? "Đang hợp tác" : "Ngưng hợp tác")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@supplier.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                            <form asp-action="ToggleActive" asp-route-id="@supplier.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(supplier.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                    @(supplier.IsActive ? "Ngưng" : "Hợp tác lại")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Chưa có nhà cung cấp nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
