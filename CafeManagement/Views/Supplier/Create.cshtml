@model CafeManagement.Models.Domain.Supplier
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm Nhà cung cấp";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">← Quay lại</a>
    <h4 class="fw-bold mb-0">Thêm Nhà cung cấp mới</h4>
</div>

<div class="card p-4" style="max-width:500px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-semibold">Tên nhà cung cấp <span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control" placeholder="VD: Công ty cà phê Trung Nguyên" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Phone" class="form-label fw-semibold">Điện thoại</label>
            <input asp-for="Phone" class="form-control" placeholder="0901234567" />
        </div>
        <div class="mb-3">
            <label asp-for="Address" class="form-label fw-semibold">Địa chỉ</label>
            <input asp-for="Address" class="form-control" placeholder="Địa chỉ nhà cung cấp" />
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary px-4">Lưu</button>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
