@model CafeManagement.Models.ViewModels.ScheduleWeekViewModel
@{
    ViewData["Title"] = "Lịch Làm Việc";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    string[] dayLabels = { "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "Chủ Nhật" };
    var prevWeek  = Model.WeekStart.AddDays(-7).ToString("yyyy-MM-dd");
    var nextWeek  = Model.WeekStart.AddDays(7).ToString("yyyy-MM-dd");
    bool isAdmin  = User.IsInRole("Admin") || User.IsInRole("Manager");
}

@section Styles {
<style>
    .schedule-page { font-size: 1rem; }

    .schedule-table th, .schedule-table td { vertical-align: middle; }

    .schedule-table thead th {
        color: #000;
        font-size: 1rem;
    }
    .schedule-table thead th.today-col { color: #000 !important; }

    .schedule-cell {
        min-width: 130px;
        vertical-align: top !important;
        padding: 6px 8px !important;
    }

    /* ── Badge nhân viên ── */
    .badge-user {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #d1fae5;
        color: #065f46;
        border-radius: 6px;
        padding: 3px 10px;
        font-size: 0.9rem;
        margin-bottom: 3px;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 160px;
    }
    /* icon chấm công trong badge */
    .badge-user .attend-icon { flex-shrink: 0; font-size: 0.85rem; }
    .badge-user.attended     { background: #bbf7d0; border: 1px solid #6ee7b7; }
    .badge-user.not-attended { background: #fef9c3; color: #92400e;
                               border: 1px dashed #fbbf24; }

    .btn-edit-cell { font-size: 0.82rem; padding: 2px 9px; margin-top: 4px; }
    .shift-label   { font-size: 0.85rem; color: #6b7280; }

    /* ── Modal checkbox cards ── */
    .user-checkbox-list {
        max-height: 320px;
        overflow-y: auto;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 6px;
    }
    .user-checkbox-list .user-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 7px 10px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.95rem;
        user-select: none;
        transition: background .15s;
    }
    .user-checkbox-list .user-item:hover  { background: #f0f9ff; }
    .user-checkbox-list .user-item.selected {
        background: #d1fae5;
        color: #065f46;
        font-weight: 600;
    }
    .user-checkbox-list .user-item .check-icon {
        width: 20px; height: 20px;
        border: 2px solid #adb5bd;
        border-radius: 4px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        font-size: 0.75rem;
        transition: all .15s;
    }
    .user-checkbox-list .user-item.selected .check-icon {
        background: #10b981;
        border-color: #10b981;
        color: #fff;
    }

    /* Chấm công modal: user-item chỉ hiện nhân viên trong ca */
    #attend-checkbox-list .user-item.attended-existing .check-icon {
        background: #10b981; border-color: #10b981; color: #fff;
    }

    #modal-assign-users, #modal-attend-users { display: none; }

    @@media print { .no-print { display: none !important; } }
</style>
}

<div class="container-fluid py-3 schedule-page">

    @* Header *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">📅 Lịch Làm Việc</h4>
    </div>

    @* Toolbar *@
    <div class="card card-body mb-3 no-print">
        <div class="row g-2 align-items-center flex-wrap">

            @* Chọn chi nhánh *@
            <div class="col-auto">
                <form method="get" id="storeForm">
                    <input type="hidden" name="weekStart" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                    <select name="storeId" class="form-select"
                            onchange="document.getElementById('storeForm').submit()">
                        @foreach (var store in Model.Stores)
                        {
                            if (store.StoreId == Model.SelectedStoreId)
                            {
                                <option value="@store.StoreId" selected="selected">🏪 @store.StoreName</option>
                            }
                            else
                            {
                                <option value="@store.StoreId">🏪 @store.StoreName</option>
                            }
                        }
                    </select>
                </form>
            </div>

            @* Điều hướng tuần *@
            <div class="col-auto d-flex gap-2">
                <a href="?storeId=@Model.SelectedStoreId&amp;weekStart=@prevWeek"
                   class="btn btn-outline-secondary btn-sm">← Tuần trước</a>

                <span class="btn btn-light btn-sm disabled fw-semibold" style="cursor:default">
                    @Model.WeekStart.ToString("dd/MM") – @Model.WeekEnd.ToString("dd/MM/yyyy")
                </span>

                <a href="?storeId=@Model.SelectedStoreId&amp;weekStart=@nextWeek"
                   class="btn btn-outline-secondary btn-sm">Tuần sau →</a>
            </div>

            @* Về tuần hiện tại *@
            <div class="col-auto">
                @{
                    var today2   = DateOnly.FromDateTime(DateTime.Today);
                    int diffNow  = ((int)today2.DayOfWeek + 6) % 7;
                    var thisMonday = today2.AddDays(-diffNow).ToString("yyyy-MM-dd");
                }
                <a href="?storeId=@Model.SelectedStoreId&amp;weekStart=@thisMonday"
                   class="btn btn-outline-primary btn-sm">Tuần này</a>
            </div>

            @* Nút Admin: Lên lịch + Chấm công *@
            @if (isAdmin)
            {
                <div class="col-auto ms-auto d-flex gap-2">
                    <button class="btn btn-primary btn-sm" id="btn-mode-assign">
                        📋 Lên lịch
                    </button>
                    <button class="btn btn-success btn-sm" id="btn-mode-attend">
                        ✅ Chấm công
                    </button>
                </div>
            }
        </div>

        @* Badge hiển thị chế độ hiện tại (chỉ Admin thấy) *@
        @if (isAdmin)
        {
            <div class="mt-2" id="mode-indicator" style="display:none">
                <span class="badge bg-primary" id="mode-label-assign" style="display:none">
                    📋 Chế độ: Lên lịch — bấm vào ô để phân công nhân viên
                </span>
                <span class="badge bg-success" id="mode-label-attend" style="display:none">
                    ✅ Chế độ: Chấm công — bấm vào ô để tick điểm danh
                </span>
                <button class="btn btn-outline-secondary btn-sm ms-2" id="btn-mode-off">
                    ✕ Thoát chế độ chỉnh sửa
                </button>
            </div>
        }
    </div>

    @* Bảng lịch *@
    <div class="table-responsive">
        <table class="table table-bordered schedule-table">
            <thead class="table-dark text-center">
                <tr>
                    <th style="min-width:150px">Ca làm việc</th>
                    @for (int i = 0; i < Model.WeekDays.Count; i++)
                    {
                        var isToday = Model.WeekDays[i] == DateOnly.FromDateTime(DateTime.Today);
                        <th class="@(isToday ? "bg-warning today-col" : "")">
                            <div>@dayLabels[i]</div>
                            <div class="fw-normal" style="font-size:0.85rem">
                                @Model.WeekDays[i].ToString("dd/MM")
                            </div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var shift in Model.Shifts)
                {
                    <tr>
                        <td class="bg-light fw-semibold text-center">
                            <div style="font-size:1rem">@shift.ShiftName</div>
                            <div class="shift-label">@shift.TimeRange</div>
                        </td>

                        @foreach (var day in Model.WeekDays)
                        {
                            var cell     = Model.GetCell(day, shift.ShiftId);
                            var isToday2 = day == DateOnly.FromDateTime(DateTime.Today);
                            <td class="schedule-cell @(isToday2 ? "table-warning" : "")">

                                @* Danh sách nhân viên với trạng thái chấm công *@
                                @if (cell.UserNames.Any())
                                {
                                    <div class="mb-1">
                                        @for (int u = 0; u < cell.UserNames.Count; u++)
                                        {
                                            bool attended = cell.AttendedUserIds.Contains(cell.UserIds[u]);
                                            <div class="badge-user @(attended ? "attended" : "not-attended")">
                                                <span class="attend-icon">@(attended ? "✅" : "⬜")</span>
                                                <span>@cell.UserNames[u]</span>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted fst-italic no-print"
                                         style="font-size:0.88rem">Chưa phân công</div>
                                }

                                @* Nút ô — chỉ Admin thấy, hiện/ẩn theo chế độ *@
                                @if (isAdmin)
                                {
                                    <button class="btn btn-outline-primary btn-edit-cell no-print btn-assign"
                                            style="display:none"
                                            data-date="@day.ToString("yyyy-MM-dd")"
                                            data-shift-id="@shift.ShiftId"
                                            data-shift-name="@shift.ShiftName"
                                            data-store-id="@Model.SelectedStoreId"
                                            data-user-ids="@string.Join(",", cell.UserIds)">
                                        ✎ Lên lịch
                                    </button>
                                    <button class="btn btn-outline-success btn-edit-cell no-print btn-attend"
                                            style="display:none"
                                            data-date="@day.ToString("yyyy-MM-dd")"
                                            data-shift-id="@shift.ShiftId"
                                            data-shift-name="@shift.ShiftName"
                                            data-store-id="@Model.SelectedStoreId"
                                            data-user-ids="@string.Join(",", cell.UserIds)"
                                            data-attended-ids="@string.Join(",", cell.AttendedUserIds)">
                                        ✔ Chấm công
                                    </button>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* ── Modal LÊN LỊCH ── *@
<div class="modal fade" id="assignModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">📋 Lên lịch — Phân công nhân viên</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="Assign" asp-controller="Schedule">
                @Html.AntiForgeryToken()
                <input type="hidden" name="storeId"  id="assign-storeId" />
                <input type="hidden" name="date"     id="assign-date" />
                <input type="hidden" name="shiftId"  id="assign-shiftId" />
                <div class="modal-body">
                    <p class="fw-semibold mb-3" id="assign-info"></p>
                    <label class="form-label fw-semibold mb-1">Chọn nhân viên</label>
                    <div class="form-text mb-2">Bấm vào tên để chọn / bỏ chọn.</div>
                    <div class="user-checkbox-list" id="assign-checkbox-list">
                        @foreach (var user in Model.AllUsers)
                        {
                            <div class="user-item" data-user-id="@user.UserId">
                                <div class="check-icon">✓</div>
                                <span>@user.FullName</span>
                            </div>
                        }
                    </div>
                    <select name="userIds" id="modal-assign-users" multiple>
                        @foreach (var user in Model.AllUsers)
                        {
                            <option value="@user.UserId">@user.FullName</option>
                        }
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">✔ Xác nhận</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ── Modal CHẤM CÔNG ── *@
<div class="modal fade" id="attendModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">✅ Chấm công</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="Attend" asp-controller="Schedule">
                @Html.AntiForgeryToken()
                <input type="hidden" name="storeId"  id="attend-storeId" />
                <input type="hidden" name="date"     id="attend-date" />
                <input type="hidden" name="shiftId"  id="attend-shiftId" />
                <div class="modal-body">
                    <p class="fw-semibold mb-3" id="attend-info"></p>
                    <label class="form-label fw-semibold mb-1">Tick nhân viên đã đi làm</label>
                    <div class="form-text mb-2">
                        Chỉ nhân viên đã được phân công mới hiển thị. Tick = đã đi làm ca này.
                    </div>
                    <div class="user-checkbox-list" id="attend-checkbox-list">
                        @* Nội dung được đổ động bằng JS dựa theo nhân viên trong ca *@
                    </div>
                    <select name="attendedUserIds" id="modal-attend-users" multiple>
                        @foreach (var user in Model.AllUsers)
                        {
                            <option value="@user.UserId">@user.FullName</option>
                        }
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">✔ Lưu chấm công</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Dữ liệu nhân viên (để đổ vào modal chấm công) ─────────────
    const allUsers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.AllUsers.Select(u => new { userId = u.UserId, fullName = u.FullName })
    ));

    // ── Quản lý chế độ (assign / attend / off) ────────────────────
    let currentMode = 'off'; // 'off' | 'assign' | 'attend'

    function setMode(mode) {
        currentMode = mode;
        const indicator    = document.getElementById('mode-indicator');
        const labelAssign  = document.getElementById('mode-label-assign');
        const labelAttend  = document.getElementById('mode-label-attend');

        if (mode === 'off') {
            indicator.style.display = 'none';
            labelAssign.style.display = 'none';
            labelAttend.style.display = 'none';
        } else {
            indicator.style.display = 'block';
            labelAssign.style.display = mode === 'assign' ? 'inline' : 'none';
            labelAttend.style.display = mode === 'attend' ? 'inline' : 'none';
        }

        // Hiện/ẩn nút trong từng ô
        document.querySelectorAll('.btn-assign').forEach(btn => {
            btn.style.display = mode === 'assign' ? 'inline-block' : 'none';
        });
        document.querySelectorAll('.btn-attend').forEach(btn => {
            btn.style.display = mode === 'attend' ? 'inline-block' : 'none';
        });
    }

    document.getElementById('btn-mode-assign')?.addEventListener('click', () => setMode('assign'));
    document.getElementById('btn-mode-attend')?.addEventListener('click', () => setMode('attend'));
    document.getElementById('btn-mode-off')?.addEventListener('click',    () => setMode('off'));

    // ── Modal LÊN LỊCH ────────────────────────────────────────────
    const assignModal = new bootstrap.Modal(document.getElementById('assignModal'));

    document.querySelectorAll('.btn-assign').forEach(btn => {
        btn.addEventListener('click', function () {
            const date        = this.dataset.date;
            const shiftId     = this.dataset.shiftId;
            const shiftName   = this.dataset.shiftName;
            const storeId     = this.dataset.storeId;
            const assignedIds = (this.dataset.userIds || '').split(',').filter(Boolean);

            document.getElementById('assign-storeId').value = storeId;
            document.getElementById('assign-date').value    = date;
            document.getElementById('assign-shiftId').value = shiftId;

            const [y, m, d] = date.split('-');
            document.getElementById('assign-info').textContent =
                `${shiftName}  —  Ngày ${d}/${m}/${y}`;

            document.querySelectorAll('#assign-checkbox-list .user-item').forEach(item => {
                item.classList.toggle('selected', assignedIds.includes(item.dataset.userId));
            });
            syncSelect('assign-checkbox-list', 'modal-assign-users');
            assignModal.show();
        });
    });

    document.querySelectorAll('#assign-checkbox-list .user-item').forEach(item => {
        item.addEventListener('click', function () {
            this.classList.toggle('selected');
            syncSelect('assign-checkbox-list', 'modal-assign-users');
        });
    });

    // ── Modal CHẤM CÔNG ───────────────────────────────────────────
    const attendModal = new bootstrap.Modal(document.getElementById('attendModal'));

    document.querySelectorAll('.btn-attend').forEach(btn => {
        btn.addEventListener('click', function () {
            const date        = this.dataset.date;
            const shiftId     = this.dataset.shiftId;
            const shiftName   = this.dataset.shiftName;
            const storeId     = this.dataset.storeId;
            const userIds     = (this.dataset.userIds     || '').split(',').filter(Boolean);
            const attendedIds = (this.dataset.attendedIds || '').split(',').filter(Boolean);

            document.getElementById('attend-storeId').value = storeId;
            document.getElementById('attend-date').value    = date;
            document.getElementById('attend-shiftId').value = shiftId;

            const [y, m, d] = date.split('-');
            document.getElementById('attend-info').textContent =
                `${shiftName}  —  Ngày ${d}/${m}/${y}`;

            // Chỉ đổ nhân viên đã được phân công vào ca này
            const listEl = document.getElementById('attend-checkbox-list');
            listEl.innerHTML = '';

            if (userIds.length === 0) {
                listEl.innerHTML = '<div class="text-muted p-2">Ca này chưa được phân công nhân viên.</div>';
            } else {
                userIds.forEach(uid => {
                    const user    = allUsers.find(u => u.userId === uid);
                    if (!user) return;
                    const already = attendedIds.includes(uid);
                    const item    = document.createElement('div');
                    item.className = 'user-item' + (already ? ' selected' : '');
                    item.dataset.userId = uid;
                    item.innerHTML = `<div class="check-icon">${already ? '✓' : ''}</div><span>${user.fullName}</span>`;
                    item.addEventListener('click', function () {
                        this.classList.toggle('selected');
                        const ci = this.querySelector('.check-icon');
                        ci.textContent = this.classList.contains('selected') ? '✓' : '';
                        syncSelect('attend-checkbox-list', 'modal-attend-users');
                    });
                    listEl.appendChild(item);
                });
            }

            syncSelect('attend-checkbox-list', 'modal-attend-users');
            attendModal.show();
        });
    });

    // ── Sync helper: checkbox list → hidden select ─────────────────
    function syncSelect(listId, selectId) {
        const select      = document.getElementById(selectId);
        const selectedIds = Array.from(
            document.querySelectorAll(`#${listId} .user-item.selected`)
        ).map(el => el.dataset.userId);
        Array.from(select.options).forEach(opt => {
            opt.selected = selectedIds.includes(opt.value);
        });
    }
</script>
}