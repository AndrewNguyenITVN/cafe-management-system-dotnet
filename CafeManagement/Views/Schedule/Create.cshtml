@model CafeManagement.Models.Domain.Schedule

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Create Schedule</h2>

<form asp-action="Create" method="post">

    @Html.AntiForgeryToken()

    <div class="form-group">
        <label>Employee</label>
        <select asp-for="UserId" class="form-control" required>
            <option value="">-- Select Employee --</option>
            @foreach (var u in ViewBag.Users)
            {
                <option value="@u.Id">@u.FullName (@u.Email)</option>
            }
        </select>

        <span asp-validation-for="UserId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Store</label>
        <select asp-for="StoreId" class="form-control" required>
            <option value="">-- Select Store --</option>
            @foreach (var s in ViewBag.Stores)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>

        <span asp-validation-for="StoreId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Shift</label>
        <select asp-for="ShiftId" class="form-control" required>
            <option value="">-- Select Shift --</option>
            @foreach (var sh in ViewBag.Shifts)
            {
                <option value="@sh.Id">@sh.ShiftName (@sh.StartTime - @sh.EndTime)</option>
            }
        </select>

        <span asp-validation-for="ShiftId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Date</label>
        <input asp-for="WorkDate" type="date" class="form-control" required />

        <span asp-validation-for="WorkDate" class="text-danger"></span>
    </div>

    <br />

    <button type="submit" class="btn btn-success">
        Create
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Back
    </a>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}