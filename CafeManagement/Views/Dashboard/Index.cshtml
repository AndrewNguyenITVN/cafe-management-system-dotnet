@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<h4 class="mb-4 fw-bold">📊 Dashboard</h4>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card revenue p-3">
            <div class="text-muted small">Doanh thu hôm nay</div>
            <div class="fs-4 fw-bold text-success">--,---,---đ</div>
            <div class="text-muted small">Toàn hệ thống</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card orders p-3">
            <div class="text-muted small">Đơn hàng hôm nay</div>
            <div class="fs-4 fw-bold text-primary">---</div>
            <div class="text-muted small">Tất cả chi nhánh</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card staff p-3">
            <div class="text-muted small">Nhân viên đang làm</div>
            <div class="fs-4 fw-bold text-warning">---</div>
            <div class="text-muted small">Hôm nay</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card warning p-3">
            <div class="text-muted small">Cảnh báo tồn kho</div>
            <div class="fs-4 fw-bold text-danger">---</div>
            <div class="text-muted small">Nguyên liệu sắp hết</div>
        </div>
    </div>
</div>

<div class="card p-4">
    <p class="text-muted text-center py-3">
        📈 Biểu đồ doanh thu sẽ được TV5 tích hợp tại đây.
    </p>
</div>
