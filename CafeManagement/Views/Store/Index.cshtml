@model IEnumerable<CafeManagement.Models.Domain.Store>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Chi nhánh";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">🏪 Quản lý Chi nhánh</h4>
    <a asp-action="Create" class="btn btn-primary">+ Thêm chi nhánh</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tên chi nhánh</th>
                    <th>Địa chỉ</th>
                    <th>Hotline</th>
                    <th>Giờ hoạt động</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (store, i) in Model.Select((s, i) => (s, i + 1)))
                {
                    <tr>
                        <td>@i</td>
                        <td class="fw-semibold">@store.Name</td>
                        <td>@(store.Address ?? "—")</td>
                        <td>@(store.Phone ?? "—")</td>
                        <td>
                            @(store.OpenTime.HasValue ? store.OpenTime.Value.ToString("HH:mm") : "--")
                            –
                            @(store.CloseTime.HasValue ? store.CloseTime.Value.ToString("HH:mm") : "--")
                        </td>
                        <td>
                            <span class="badge @(store.IsActive ? "bg-success" : "bg-secondary")">
                                @(store.IsActive ? "Đang hoạt động" : "Tạm đóng")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@store.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                            <form asp-action="ToggleActive" asp-route-id="@store.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(store.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                    @(store.IsActive ? "Tạm đóng" : "Mở lại")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Chưa có chi nhánh nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
