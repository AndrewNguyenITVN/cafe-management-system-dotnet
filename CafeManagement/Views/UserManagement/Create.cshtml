@model CafeManagement.Models.ViewModels.CreateUserViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm Nhân viên";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">← Quay lại</a>
    <h4 class="fw-bold mb-0">Thêm Nhân viên mới</h4>
</div>

<div class="card p-4" style="max-width: 600px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

        <div class="mb-3">
            <label asp-for="FullName" class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
            <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
            <span asp-validation-for="FullName" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
            <input asp-for="Email" class="form-control" placeholder="nhanvien@cafe.com" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>
        <div class="row mb-3">
            <div class="col">
                <label asp-for="Role" class="form-label fw-semibold">Vai trò <span class="text-danger">*</span></label>
                <select asp-for="Role" asp-items="ViewBag.Roles" class="form-select"></select>
                <span asp-validation-for="Role" class="text-danger small"></span>
            </div>
            <div class="col">
                <label asp-for="PositionId" class="form-label fw-semibold">Chức vụ</label>
                <select asp-for="PositionId" asp-items="ViewBag.Positions" class="form-select">
                    <option value="">-- Chọn chức vụ --</option>
                </select>
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="StoreId" class="form-label fw-semibold">Chi nhánh</label>
            <select asp-for="StoreId" asp-items="ViewBag.Stores" class="form-select">
                <option value="">-- Chọn chi nhánh --</option>
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="PinCode" class="form-label fw-semibold">Mã PIN (6 số)</label>
            <input asp-for="PinCode" class="form-control" placeholder="123456" maxlength="6" pattern="\d{6}" />
            <div class="form-text">Dùng để chấm công tại máy POS.</div>
            <span asp-validation-for="PinCode" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary px-4">Lưu</button>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
