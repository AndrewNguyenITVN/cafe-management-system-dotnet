@model CafeManagement.Models.ViewModels.JobPositionViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sửa Chức vụ";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">← Quay lại</a>
    <h4 class="fw-bold mb-0">Sửa Chức vụ: @Model.PositionName</h4>
</div>

<div class="card p-4" style="max-width:500px;">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

        <div class="mb-3">
            <label asp-for="PositionName" class="form-label fw-semibold">Tên chức vụ <span class="text-danger">*</span></label>
            <input asp-for="PositionName" class="form-control" />
            <span asp-validation-for="PositionName" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="HourlyRate" class="form-label fw-semibold">Mức lương/giờ (VNĐ) <span class="text-danger">*</span></label>
            <input asp-for="HourlyRate" class="form-control" />
            <span asp-validation-for="HourlyRate" class="text-danger small"></span>
        </div>
        <div class="mb-3 form-check">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">Đang dùng</label>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
