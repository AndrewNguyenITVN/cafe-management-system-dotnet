@model IEnumerable<CafeManagement.Models.Domain.JobPosition>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Chức vụ & Lương";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">💼 Quản lý Chức vụ & Lương</h4>
    <a asp-action="Create" class="btn btn-primary">+ Thêm chức vụ</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tên chức vụ</th>
                    <th>Mức lương/giờ</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (pos, i) in Model.Select((p, i) => (p, i + 1)))
                {
                    <tr>
                        <td>@i</td>
                        <td class="fw-semibold">@pos.PositionName</td>
                        <td class="text-success fw-semibold">@pos.HourlyRate.ToString("N0")đ/giờ</td>
                        <td>
                            <span class="badge @(pos.IsActive ? "bg-success" : "bg-secondary")">
                                @(pos.IsActive ? "Đang dùng" : "Không dùng")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@pos.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Chưa có chức vụ nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
