@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>☕ Cafe Management - Chọn màn hình</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap');

        * { box-sizing: border-box; }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: #0f0a06;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 32px 16px;
            color: #f7e6c4;
            overflow-x: hidden;
        }

        /* Nền hình trang trí */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse at 20% 20%, rgba(212,163,115,.12) 0%, transparent 55%),
                radial-gradient(ellipse at 80% 80%, rgba(176,125,75,.10) 0%, transparent 55%);
            pointer-events: none;
        }

        .brand {
            text-align: center;
            margin-bottom: 48px;
        }
        .brand-icon {
            font-size: 56px;
            line-height: 1;
        }
        .brand-title {
            font-size: 2.4rem;
            font-weight: 800;
            color: #d4a373;
            letter-spacing: 1px;
            margin: 8px 0 4px;
        }
        .brand-sub {
            font-size: 1rem;
            color: #8a7060;
            font-weight: 400;
        }

        /* Grid thẻ */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            width: 100%;
            max-width: 760px;
        }
        @@media (max-width: 540px) {
            .card-grid { grid-template-columns: 1fr; }
            .brand-title { font-size: 1.8rem; }
        }

        /* Thẻ điều hướng */
        .nav-card {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            padding: 28px 28px 24px;
            border-radius: 20px;
            text-decoration: none;
            color: #f7e6c4;
            background-color: #1e1208;
            border: 1px solid #3d2a1c;
            position: relative;
            overflow: hidden;
            transition: transform .25s cubic-bezier(.4,0,.2,1),
                        box-shadow .25s cubic-bezier(.4,0,.2,1),
                        border-color .25s;
            cursor: pointer;
        }
        .nav-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(212,163,115,.08) 0%, transparent 60%);
            opacity: 0;
            transition: opacity .25s;
        }
        .nav-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(0,0,0,.5);
            border-color: var(--accent);
            color: #f7e6c4;
            text-decoration: none;
        }
        .nav-card:hover::before { opacity: 1; }

        .card-icon {
            font-size: 2.6rem;
            line-height: 1;
            margin-bottom: 16px;
            padding: 14px;
            border-radius: 14px;
            background-color: rgba(255,255,255,.04);
            border: 1px solid rgba(255,255,255,.06);
        }
        .card-title {
            font-size: 1.2rem;
            font-weight: 700;
            margin: 0 0 6px;
            letter-spacing: .3px;
        }
        .card-desc {
            font-size: .85rem;
            color: #8a7060;
            line-height: 1.5;
            flex-grow: 1;
        }
        .card-arrow {
            margin-top: 20px;
            font-size: .82rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--accent);
            opacity: .7;
            transition: opacity .2s, gap .2s;
        }
        .nav-card:hover .card-arrow {
            opacity: 1;
            gap: 10px;
        }

        /* Màu accent riêng từng thẻ */
        .card-admin   { --accent: #d4a373; }
        .card-pos     { --accent: #7ec8e3; }
        .card-kds     { --accent: #f4a261; }
        .card-display { --accent: #90e0ae; }

        .card-admin   .card-icon { color: #d4a373; }
        .card-pos     .card-icon { color: #7ec8e3; }
        .card-kds     .card-icon { color: #f4a261; }
        .card-display .card-icon { color: #90e0ae; }

        .card-admin:hover   { box-shadow: 0 20px 40px rgba(212,163,115,.15); }
        .card-pos:hover     { box-shadow: 0 20px 40px rgba(126,200,227,.12); }
        .card-kds:hover     { box-shadow: 0 20px 40px rgba(244,162,97,.12);  }
        .card-display:hover { box-shadow: 0 20px 40px rgba(144,224,174,.12); }

        /* Badge góc */
        .badge-corner {
            position: absolute;
            top: 14px;
            right: 16px;
            font-size: .68rem;
            font-weight: 700;
            padding: 3px 9px;
            border-radius: 999px;
            letter-spacing: .5px;
            text-transform: uppercase;
        }
        .badge-admin   { background: rgba(212,163,115,.15); color: #d4a373; border: 1px solid rgba(212,163,115,.3); }
        .badge-pos     { background: rgba(126,200,227,.12); color: #7ec8e3; border: 1px solid rgba(126,200,227,.3); }
        .badge-kds     { background: rgba(244,162,97,.12);  color: #f4a261; border: 1px solid rgba(244,162,97,.3);  }
        .badge-display { background: rgba(144,224,174,.12); color: #90e0ae; border: 1px solid rgba(144,224,174,.3); }

        .footer-note {
            margin-top: 40px;
            font-size: .78rem;
            color: #4a3422;
            text-align: center;
        }
    </style>
</head>
<body>

    <div class="brand">
        <div class="brand-icon">☕</div>
        <div class="brand-title">Cafe Management</div>
        <div class="brand-sub">Chọn màn hình để bắt đầu</div>
    </div>

    <div class="card-grid">

        <a href="/Dashboard/Index" class="nav-card card-admin">
            <span class="badge-corner badge-admin">Admin</span>
            <div class="card-icon">🛠️</div>
            <div class="card-title">Quản trị hệ thống</div>
            <div class="card-desc">Quản lý nhân viên, thực đơn, chi nhánh, tồn kho và báo cáo doanh thu.</div>
            <div class="card-arrow">Vào Dashboard <span>→</span></div>
        </a>

        <a href="/Pos/Index" class="nav-card card-pos">
            <span class="badge-corner badge-pos">POS</span>
            <div class="card-icon">🧾</div>
            <div class="card-title">Máy thu ngân</div>
            <div class="card-desc">Nhập PIN, tạo đơn hàng, thanh toán và kết ca cho thu ngân.</div>
            <div class="card-arrow">Vào POS <span>→</span></div>
        </a>

        <a href="/Pos/Kds" class="nav-card card-kds">
            <span class="badge-corner badge-kds">Bếp</span>
            <div class="card-icon">👨‍🍳</div>
            <div class="card-title">Màn hình bếp (KDS)</div>
            <div class="card-desc">Xem danh sách đơn hàng đang chờ, cập nhật trạng thái từng đơn theo thời gian thực.</div>
            <div class="card-arrow">Vào KDS <span>→</span></div>
        </a>

        <a href="/Pos/CustomerDisplay" class="nav-card card-display">
            <span class="badge-corner badge-display">Hiển thị</span>
            <div class="card-icon">📺</div>
            <div class="card-title">Màn hình khách hàng</div>
            <div class="card-desc">Màn hình thông báo số thứ tự và trạng thái đơn hàng dành cho khách ngồi chờ.</div>
            <div class="card-arrow">Mở màn hình <span>→</span></div>
        </a>

    </div>

    <div class="footer-note">
        Cafe Management System &nbsp;·&nbsp; v1.0
    </div>

</body>
</html>
