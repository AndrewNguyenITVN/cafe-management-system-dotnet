@model List<CafeManagement.Models.Domain.InventoryStock>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tồn Kho";
    var stores = ViewBag.Stores as List<CafeManagement.Models.Domain.Store> ?? new List<CafeManagement.Models.Domain.Store>();
    int? selectedStoreId = ViewBag.SelectedStoreId as int?;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Danh sách Tồn Kho</h4>
    <a asp-action="Purchase" class="btn btn-success">+ Nhập Kho</a>
</div>

@if (ViewBag.ManagerStoreId != null)
{
    <div class="mb-4">
        <span class="badge bg-secondary fs-6">@ViewBag.ManagerStoreName</span>
    </div>
}
else
{
    <form method="get" class="mb-4">
        <div class="row">
            <div class="col-md-4">
                <select name="storeId" class="form-select" onchange="this.form.submit()">
                    <option value="">-- Chọn cửa hàng --</option>
                    @foreach (var s in stores)
                    {
                        if (s.Id == selectedStoreId) { <option value="@s.Id" selected>@s.Name</option> }
                        else { <option value="@s.Id">@s.Name</option> }
                    }
                </select>
            </div>
        </div>
    </form>
}

@if (Model != null && Model.Any())
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>STT</th>
                        <th>Nguyên liệu</th>
                        <th>Đơn vị</th>
                        <th class="text-end">Tồn hiện tại</th>
                        <th class="text-end">Mức tối thiểu</th>
                        <th class="text-center">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var stock in Model)
                    {
                        bool isLow = stock.CurrentQuantity < (stock.Ingredient?.MinStockLevel ?? 0);
                        <tr class="@(isLow ? "table-danger" : "")">
                            <td>@(i++)</td>
                            <td class="fw-semibold">@stock.Ingredient?.Name</td>
                            <td>@stock.Ingredient?.Unit</td>
                            <td class="text-end fw-bold">@stock.CurrentQuantity.ToString("N2")</td>
                            <td class="text-end text-muted">@stock.Ingredient?.MinStockLevel.ToString("N2")</td>
                            <td class="text-center">
                                @if (isLow)
                                {
                                    <span class="badge bg-danger">⚠ Sắp hết</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">✓ Đủ hàng</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">Chọn cửa hàng để xem tồn kho, hoặc chưa có dữ liệu nguyên liệu.</div>
}
