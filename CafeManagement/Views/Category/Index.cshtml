@model IEnumerable<CafeManagement.Models.Domain.Category>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">📂 Quản lý Danh mục món</h4>
    <a asp-action="Create" class="btn btn-primary">+ Thêm danh mục</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tên danh mục</th>
                    <th>Mô tả</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (cat, i) in Model.Select((c, i) => (c, i + 1)))
                {
                    <tr>
                        <td>@i</td>
                        <td class="fw-semibold">@cat.Name</td>
                        <td class="text-muted">@(cat.Description ?? "—")</td>
                        <td>
                            <span class="badge @(cat.IsActive ? "bg-success" : "bg-secondary")">
                                @(cat.IsActive ? "Đang dùng" : "Ẩn")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                            <form asp-action="ToggleActive" asp-route-id="@cat.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(cat.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                    @(cat.IsActive ? "Ẩn" : "Hiện")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Chưa có danh mục nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
