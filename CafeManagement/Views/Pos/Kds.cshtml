@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KDS - Màn Hình Nhà Bếp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&display=swap');
        body { background-color: #1a120b; color: #f7e6c4; padding: 20px; font-family: 'Outfit', sans-serif; }
        h1 { color: #d4a373; font-weight: 700; letter-spacing: 1px; }
        .order-card { 
            background: linear-gradient(145deg, #2b1f14, #1a120b); 
            border: 2px solid #5c3a21; 
            border-radius: 16px; 
            padding: 20px; 
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
            transition: all 0.3s ease;
        }
        .order-card.blink { 
            animation: blinker 1.5s cubic-bezier(0.4, 0, 0.2, 1) infinite; 
            border-color: #e07a5f; 
            box-shadow: 0 0 15px rgba(224, 122, 95, 0.4);
        }
        .queue-number { font-size: 2.5rem; font-weight: bold; color: #d4a373; }
        .list-group-item.bg-dark { background-color: #3d2a1c !important; color: #f7e6c4 !important; border-color: #5c3a21; }
        .badge.bg-danger { background-color: #e07a5f !important; }
        .btn-success { background-color: #6c584c; border: none; color: #f7e6c4; font-size: 1.1rem; transition: background 0.3s; }
        .btn-success:hover { background-color: #4a3422; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
        .btn-warning { background-color: #d4a373; border: none; color: #1a120b; font-size: 1.1rem; transition: background 0.3s; }
        .btn-warning:hover { background-color: #b07d4b; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
        @@keyframes blinker { 50% { opacity: 0.8; border-color: #8d3a24; } }
        /* Store picker overlay */
        #store-picker { position:fixed; inset:0; background:rgba(15,8,3,0.96); z-index:9999; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:32px; }
        #store-picker h2 { color:#d4a373; font-size:2rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; }
        .store-btn { background:linear-gradient(145deg,#3d2a1c,#2b1f14); border:2px solid #5c3a21; color:#f7e6c4; border-radius:14px; padding:22px 48px; font-size:1.4rem; font-weight:700; cursor:pointer; transition:all .25s; min-width:260px; text-align:center; }
        .store-btn:hover { border-color:#d4a373; color:#d4a373; box-shadow:0 0 18px rgba(212,163,115,.35); transform:scale(1.04); }
    </style>
</head>
<body>

    <!-- Overlay chọn chi nhánh (chỉ hiện khi chưa có storeId trong URL) -->
    <div id="store-picker">
        <h2>Chọn Chi Nhánh</h2>
        <div id="store-btn-list" style="display:flex;flex-direction:column;gap:16px;"></div>
    </div>

    <div class="d-flex justify-content-between mb-4">
        <h1>KITCHEN DISPLAY (<span id="storeNameId"></span>)</h1>
        <div>
            <button onclick="changeBranch()" class="btn btn-outline-warning btn-sm me-3">🔄 Đổi chi nhánh</button>
            <span id="conn-status" class="badge bg-danger">Đang ngắt kết nối</span>
        </div>
    </div>

    <div class="row g-4" id="kds-board">
        <!-- Danh sách thẻ Order sẽ được render bằng JS ở đây -->
    </div>

    <!-- 1. Thẻ Audio để phát tiếng báo đơn mới -->
    <audio id="notification-sound" src="https://actions.google.com/sounds/v1/alarms/beep_short.ogg" preload="auto"></audio>

    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        let storeId = urlParams.get('storeId');
        let storeName = '';

        async function loadStorePicker() {
            try {
                const res = await fetch('/Pos/GetStores');
                const stores = await res.json();
                const btnList = document.getElementById('store-btn-list');
                btnList.innerHTML = '';
                stores.forEach(s => {
                    const btn = document.createElement('button');
                    btn.className = 'store-btn';
                    btn.textContent =  s.name;
                    btn.onclick = () => {
                        const url = new URL(window.location.href);
                        url.searchParams.set('storeId', s.id);
                        window.location.href = url.toString();
                    };
                    btnList.appendChild(btn);
                });
            } catch(e) {
                document.getElementById('store-btn-list').innerHTML = '<p style="color:#f87171">Lỗi tải danh sách chi nhánh</p>';
            }
        }

        function changeBranch() {
            document.getElementById('store-picker').style.display = 'flex';
            loadStorePicker();
        }

        // Nếu chưa chọn chi nhánh → hiện overlay, ngược lại → ẩn overlay và load tên
        if (!storeId) {
            loadStorePicker();
        } else {
            document.getElementById('store-picker').style.display = 'none';
            // Lấy tên chi nhánh từ API để hiển thị đẹp hơn số ID
            fetch('/Pos/GetStores').then(r => r.json()).then(stores => {
                const found = stores.find(s => String(s.id) === String(storeId));
                document.getElementById('storeNameId').textContent = found ? found.name : 'Chi nhánh ' + storeId;
            });
        }
        const board = document.getElementById('kds-board');
        const statusBadge = document.getElementById('conn-status');

        // === HÀM DÙNG CHUNG: Vẽ 1 thẻ đơn hàng lên bảng KDS ===
        function renderOrderCard(data) {
            // Chống trùng lặp
            if (document.getElementById('order-card-' + data.orderId)) return;

            let itemsHtml = '<ul class="list-group list-group-flush mb-3 rounded">';
            if (data.items && data.items.length > 0) {
                data.items.forEach(item => {
                    itemsHtml += `<li class="list-group-item bg-dark text-light border-secondary">
                        <span class="fw-bold" style="color: yellow;">${item.quantity}x</span> ${item.name}
                    </li>`;
                });
            }
            itemsHtml += '</ul>';

            // Xác định giao diện theo trạng thái
            const isProcessing = data.status === 1;
            const badgeClass = isProcessing ? 'badge bg-warning text-dark' : 'badge bg-danger';
            const badgeText = isProcessing ? 'ĐANG NẤU' : 'MỚI';
            const blinkClass = isProcessing ? '' : 'blink';
            const borderColor = isProcessing ? 'border-color: #f4a261;' : '';
            
            // Nút chính
            const btnClass = isProcessing ? 'btn btn-success' : 'btn btn-warning';
            const btnText = isProcessing ? 'XONG ĐƠN' : 'BẮT ĐẦU NẤU';
            const nextStatus = isProcessing ? 2 : 1;

            const cardHtml = `
                <div class="col-3" id="order-card-${data.orderId}">
                    <div class="order-card ${blinkClass}" id="order-inner-${data.orderId}" style="${borderColor}">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="queue-number">#${data.queueNumber}</div>
                            <span class="${badgeClass}" id="badge-${data.orderId}">${badgeText}</span>
                        </div>
                        <p class="mb-2 text-secondary">ID Đơn: ${data.orderId}</p>
                        
                        ${itemsHtml}
                        
                        <button class="${btnClass} w-100 fw-bold py-2 shadow mb-2" id="btn-status-${data.orderId}" onclick="updateOrderStatus(${data.orderId}, ${nextStatus}, this)">
                            ${btnText}
                        </button>
                        <button class="btn btn-outline-danger w-100 fw-bold py-1" onclick="cancelOrder(${data.orderId})">
                            ❌ HỦY ĐƠN
                        </button>
                    </div>
                </div>
            `;
            
            board.insertAdjacentHTML('afterbegin', cardHtml);
        }

        // === LOAD LẠI ĐƠN TỪ DATABASE KHI F5 / MỞ TRANG ===
        async function loadActiveOrders() {
            try {
                const res = await fetch('/Pos/GetActiveOrders?storeId=' + storeId);
                const orders = await res.json();
                orders.forEach(order => renderOrderCard(order));
            } catch(e) {
                console.error("Lỗi load đơn hàng:", e);
            }
        }

        // 1. Khởi tạo SignalR Connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/orderHub")
            .withAutomaticReconnect()
            .build();

        // 2. Lắng nghe sự kiện NewOrderReceived
        connection.on("NewOrderReceived", function (data) {
            renderOrderCard(data);
            try {
                document.getElementById('notification-sound').play();
            } catch (e) {
                console.log("Trình duyệt chặn Autoplay Audio.");
            }
        });

        // 3. Thay đổi trạng thái đơn hàng (1: Đang nấu, 2: Xong)
        function updateOrderStatus(orderId, status, btnElement) {
            const oldText = btnElement.innerHTML;
            btnElement.disabled = true;
            btnElement.innerHTML = "⏳ Đang xử lý...";

            fetch('/Pos/UpdateOrderStatus?orderId=' + orderId + '&status=' + status, {
                method: 'POST'
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    if (status === 1) {
                        btnElement.className = "btn btn-success w-100 fw-bold py-2 shadow mb-2";
                        btnElement.innerHTML = "XONG ĐƠN";
                        btnElement.onclick = function() { updateOrderStatus(orderId, 2, this); };
                        btnElement.disabled = false;
                        
                        const badge = document.getElementById('badge-' + orderId);
                        if (badge) {
                            badge.className = "badge bg-warning text-dark";
                            badge.innerText = "ĐANG NẤU";
                        }
                        const card = document.getElementById('order-inner-' + orderId);
                        if (card) {
                            card.classList.remove('blink');
                            card.style.borderColor = "#f4a261";
                        }
                    } else if (status === 2) {
                        const cardOuter = document.getElementById('order-card-' + orderId);
                        if (cardOuter) cardOuter.style.display = 'none';
                    }
                } else {
                    alert(data.message);
                    btnElement.disabled = false;
                    btnElement.innerHTML = oldText;
                }
            })
            .catch(err => {
                alert("Lỗi kết nối API");
                btnElement.disabled = false;
                btnElement.innerHTML = oldText;
            });
        }

        // 4. HỦY ĐƠN HÀNG
        function cancelOrder(orderId) {
            if (!confirm('Bạn có chắc chắn muốn HỦY đơn #' + orderId + '?')) return;

            fetch('/Pos/CancelOrder?orderId=' + orderId, { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const cardOuter = document.getElementById('order-card-' + orderId);
                    if (cardOuter) cardOuter.remove();
                } else {
                    alert(data.message);
                }
            })
            .catch(err => alert("Lỗi hủy đơn: " + err.message));
        }

        // 5. Bắt đầu kết nối
        async function start() {
            try {
                await connection.start();
                statusBadge.textContent = "🟢 Đã kết nối Mạng";
                statusBadge.className = "badge bg-success";

                await connection.invoke("JoinGroup", storeId);
                
                // Load lại đơn đang hoạt động từ DB
                await loadActiveOrders();
            } catch (err) {
                console.error(err);
                setTimeout(start, 5000);
            }
        }

        start();
    </script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</body>
</html>
