    function submitPin() {
        if (!selectedCashierId) {
            alert("Vui lòng chọn nhân viên trong danh sách trước khi nhập PIN.");
            return;
        }

        if (currentPin.length < 4) {
            alert("Mã PIN phải ít nhất 4 số!");
            return;
        }

        fetch('/Pos/VerifyPin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                pinCode: currentPin,
                userId: selectedCashierId
            })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                activeCashierId = data.userId;
                activeCashierName = data.cashierName;
                currentStoreId = data.storeId || 1;

                const overlay = document.getElementById('pin-overlay');
                overlay.classList.remove('d-flex');
                overlay.classList.add('d-none');

                // Sau khi đăng nhập ca thành công mới load menu POS
                loadCategories();
            } else {
                document.getElementById('pin-error').textContent = data.message || "Mã PIN không đúng!";
                document.getElementById('pin-error').classList.remove('d-none');
                clearPin();
            }
        });
    }

    //Hàm load nhân viên
    async function loadCashiers() {
        const box = document.getElementById('cashier-list-box');
        if (!box) return;
        try {
            const res = await fetch('/Pos/GetCashiers', { credentials: 'same-origin' });
            if (!res.ok) {
                box.innerHTML = '<p class="text-danger text-center small py-3 mb-0">Lỗi tải danh sách (HTTP ' + res.status + ')</p>';
                return;
            }
            const data = await res.json();

            // Backend có thể trả array hoặc object có property (tương thích cả PascalCase/camelCase)
            const list = Array.isArray(data) ? data : (data.data || data.items || []);
            if (list.length === 0) {
                box.innerHTML = '<p class="text-secondary text-center small py-3 mb-0">Chưa có nhân viên</p>';
                return;
            }

            box.innerHTML = '';
            list.forEach(c => {
                const id = c.id ?? c.Id ?? '';
                const name = (c.name ?? c.Name ?? '').trim() || 'Nhân viên';
                const div = document.createElement('div');
                div.className = 'cashier-item';
                div.dataset.id = id;
                div.dataset.name = name;
                div.textContent = name;

                div.onclick = function () {
                    document.querySelectorAll('#cashier-list-box .cashier-item').forEach(el => el.classList.remove('selected'));
                    this.classList.add('selected');
                    selectedCashierId = this.dataset.id;
                };

                box.appendChild(div);
            });
        } catch (e) {
            console.error('Lỗi load danh sách nhân viên:', e);
            box.innerHTML = '<p class="text-danger text-center small py-3 mb-0">Lỗi tải danh sách</p>';
        }
    }

    // Cuối script: gọi load nhân viên ngay khi DOM sẵn sàng (script ở cuối body nên DOM thường đã load xong)
    function initPos() {
        loadCashiers();
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initPos);
    } else {
        initPos();
    }

