    function submitPin() {
        if (!selectedCashierId) {
            alert("Vui lòng chọn nhân viên trong danh sách trước khi nhập PIN.");
            return;
        }

        if (currentPin.length < 4) {
            alert("Mã PIN phải ít nhất 4 số!");
            return;
        }

        fetch('/Pos/VerifyPin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                pinCode: currentPin,
                userId: selectedCashierId
            })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                activeCashierId = data.userId;
                activeCashierName = data.cashierName;
                currentStoreId = data.storeId || 1;

                const overlay = document.getElementById('pin-overlay');
                overlay.classList.remove('d-flex');
                overlay.classList.add('d-none');

                // Sau khi đăng nhập ca thành công mới load menu POS
                loadCategories();
                
                // Thu Ngân tham gia vào Hub Group của chi nhánh sau khi có StoreId
                connection.start().then(() => {
                    connection.invoke("JoinGroup", currentStoreId.toString())
                        .catch(err => console.error("SignalR JoinGroup Error: ", err));
                }).catch(err => console.error("SignalR Start Error: ", err));
            } else {
                const msg = data.message || "Vui lòng kiểm tra lại mã PIN và thử lại.";
                const box = document.getElementById('pin-error-box');
                const msgEl = document.getElementById('pin-error-box-message');
                if (box && msgEl) {
                    msgEl.textContent = msg;
                    box.classList.remove('d-none');
                    box.classList.add('d-flex');
                }
                clearPin();
            }
        });
    }

    function closePinErrorBox() {
        const box = document.getElementById('pin-error-box');
        if (box) {
            box.classList.add('d-none');
            box.classList.remove('d-flex');
        }
    }

    function closeOrderSuccessBox() {
        const box = document.getElementById('order-success-box');
        if (box) {
            box.classList.add('d-none');
