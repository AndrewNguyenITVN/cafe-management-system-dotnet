@* Trang POS không dùng chung Layout Admin *@
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>POS - Máy Thu Ngân</title>

    @* Bootstrap CSS *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    @* Custom CSS *@
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap');

        /* ===== TOÀN TRANG ===== */
        body {
            background-color: #1a120b;  /* Nền nâu cà phê rất tối */
            color: #f7e6c4;             /* Chữ trắng kem sáng */
            font-family: 'Outfit', sans-serif;
            overflow: hidden;           /* Tắt cuộn trang (POS cố định 1 màn hình) */
            height: 100vh;              /* Chiếm hết chiều cao màn hình */
        }

        /* ===== CỘT TRÁI - DANH MỤC ===== */
        .category-panel {
            background-color: #2b1f14;  /* Nền nâu đậm */
            height: 100vh;
            padding: 20px 15px;
            overflow-y: auto;           /* Cuộn được nếu danh mục nhiều */
            border-right: 1px solid #3d2a1c;
        }
        .category-btn {
            display: block;
            width: 100%;
            padding: 16px;
            margin-bottom: 12px;
            border: 1px solid #3d2a1c;
            border-radius: 12px;
            background-color: #3d2a1c;
            color: #f7e6c4;
            font-size: 16px;
            font-weight: 600;
            text-align: left;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .category-btn::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 4px; height: 100%;
            background-color: #d4a373; /* Caramel highlight */
            transform: scaleY(0);
            transition: transform 0.3s;
        }
        .category-btn:hover {
            background-color: #4a3422;  /* Sáng hơn khi rê chuột */
            transform: translateX(4px);
        }
        .category-btn.active {
            background-color: #4a3422;  
            color: #fff;
            box-shadow: 0 4px 15px rgba(212, 163, 115, 0.2);
        }
        .category-btn.active::before {
            transform: scaleY(1);
        }

        /* ===== CỘT GIỮA - SẢN PHẨM ===== */
        .product-panel {
            height: 100vh;
            padding: 24px;
            overflow-y: auto;
            background-image: radial-gradient(circle at center, #231810 0%, #1a120b 100%);
        }
        .product-card {
            background: linear-gradient(145deg, #2b1f14, #1a120b);
            border: 1px solid #3d2a1c;
            border-radius: 16px;
            padding: 20px 16px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
            position: relative;
            overflow: hidden;
        }
        .product-card::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; width: 100%; height: 2px;
            background: #d4a373;
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        .product-card:hover {
            transform: translateY(-5px);      
            border-color: #d4a373;
            box-shadow: 0 12px 25px rgba(212, 163, 115, 0.15);
        }
        .product-card:hover::after {
            transform: scaleX(1);
        }
        .product-card .name {
            font-weight: 700;
            margin-top: 12px;
            font-size: 15px;
            letter-spacing: 0.5px;
        }
        .product-card .price {
            color: #d4a373;
            font-weight: bold;
            font-size: 18px;
            margin-top: 6px;
        }

        /* ===== CỘT PHẢI - GIỎ HÀNG ===== */
        .cart-panel {
            background-color: #2b1f14;
            height: 100vh;
            padding: 20px 24px;
            display: flex;
            flex-direction: column;      /* Xếp các phần tử theo chiều dọc */
            border-left: 1px solid #3d2a1c;
            box-shadow: -10px 0 30px rgba(0,0,0,0.5);
        }
        .cart-item {
            background-color: #3d2a1c;
            border-radius: 12px;
            padding: 12px 16px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 3px solid #6c584c;
            transition: background 0.2s;
        }
        .cart-item:hover { background-color: #4a3422; }
        .cart-item .qty-btn {
            background: #6c584c;
            color: #f7e6c4;
            border: none;
            border-radius: 6px;
            width: 28px;
            height: 28px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s;
        }
        .cart-item .qty-btn:hover {
            background: #d4a373;
            color: #1a120b;
        }
        .cart-item .item-details { flex-grow: 1; margin: 0 10px; }
        .cart-item .name { font-weight: 600; font-size: 15px; }
        .cart-item .price { color: #d4a373; font-size: 14px; margin-top: 2px; }

        .cart-summary {
            margin-top: auto;  /* Đẩy phần tổng tiền xuống cuối cột */
            background-color: #1a120b;
            padding: 20px;
            border-radius: 16px;
            border: 1px solid #3d2a1c;
        }
        .btn-checkout {
            background: linear-gradient(135deg, #d4a373, #b07d4b);
            color: #1a120b;
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 12px;
            font-size: 18px;
            font-weight: 800;
            letter-spacing: 1px;
            margin-top: 15px;
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(212, 163, 115, 0.3);
        }
        .btn-checkout:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(212, 163, 115, 0.4);
        }
        
        /* Tùy chỉnh thanh cuộn dải mỏng */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #1a120b; }
        ::-webkit-scrollbar-thumb { background: #3d2a1c; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #d4a373; }
        
        /* Tùy chỉnh input cho đẹp */
        .form-control.bg-dark {
            background-color: #1a120b !important;
            border-color: #3d2a1c !important;
            color: #f7e6c4 !important;
            padding: 12px;
            border-radius: 8px;
        }
        .form-control.bg-dark:focus {
            box-shadow: 0 0 0 0.25rem rgba(212, 163, 115, 0.25);
            border-color: #d4a373 !important;
        }
        .form-check-input:checked {
            background-color: #d4a373;
            border-color: #d4a373;
        }

        #cashier-list-box .cashier-item {
            padding: 12px 14px;
            border-bottom: 1px solid #3d2a1c;
            cursor: pointer;
            color: #f7e6c4;
            transition: background 0.2s;
        }
        #cashier-list-box .cashier-item:hover {
            background-color: #3d2a1c;
        }
        #cashier-list-box .cashier-item.selected {
            background-color: #4a3422;
            border-left: 4px solid #d4a373;
        }
        #cashier-list-box .cashier-item:last-child {
            border-bottom: none;
        }
    </style>
</head>

<body>

@* ══════════ MÀN HÌNH KHÓA PIN ══════════ *@
<div id="pin-overlay" class="position-fixed top-0 start-0 w-100 h-100 d-flex flex-column justify-content-center align-items-center" style="background-color: #1a120b; z-index: 9999;">
    <h2 class="mb-4 fw-bold" style="color: #d4a373;">🔒 MỞ CA LÀM VIỆC</h2>
    <!-- Chọn nhân viên -->
    <div class="mb-3" style="width: 280px;">
        <label class="form-label small text-secondary mb-1">Chọn nhân viên</label>
        <div id="cashier-list-box" class="border rounded overflow-y-auto bg-dark"
            style="max-height: 200px; border-color: #3d2a1c !important;">
            <p class="text-secondary text-center small py-3 mb-0">Đang tải...</p>
        </div>
    </div>
    <input type="password" id="pin-input" class="form-control bg-dark text-center text-light fs-3 mb-4 rounded-3 border-secondary" style="width: 250px; letter-spacing: 10px; height: 60px;" readonly />
    <div class="d-grid gap-2" style="grid-template-columns: repeat(3, 1fr); width: 250px;">
        <button class="btn btn-outline-light fs-4 py-2" onclick="addPin('1')">1</button>
        <button class="btn btn-outline-light fs-4 py-2" onclick="addPin('2')">2</button>
        <button class="btn btn-outline-light fs-4 py-2" onclick="addPin('3')">3</button>
        <button class="btn btn-outline-light fs-4 py-2" onclick="addPin('4')">4</button>
        <button class="btn btn-outline-light fs-4 py-2" onclick="addPin('5')">5</button>
        <button class="btn btn-outline-light fs-4 py-2" onclick="addPin('6')">6</button>
        <button class="btn btn-outline-light fs-4 py-2" onclick="addPin('7')">7</button>
        <button class="btn btn-outline-light fs-4 py-2" onclick="addPin('8')">8</button>
        <button class="btn btn-outline-light fs-4 py-2" onclick="addPin('9')">9</button>
        <button class="btn btn-danger fs-4 py-2 fw-bold" onclick="clearPin()">C</button>
        <button class="btn btn-outline-light fs-4 py-2" onclick="addPin('0')">0</button>
        <button class="btn btn-success fs-4 py-2 fw-bold" onclick="submitPin()" style="background-color: #6c584c; border:none;">OK</button>
    </div>
    <span id="pin-error" class="text-danger mt-3 d-none fw-bold fs-5">Mã PIN không đúng!</span>
</div>

@* Layout 3 cột (Grid Bootstrap) *@

<div class="container-fluid">
    <div class="row">

        @* ══════════ CỘT TRÁI: DANH MỤC ══════════ *@
        <div class="col-2 category-panel">
            <h5 class="mb-3">📋 Danh mục</h5>
            <div id="category-list">
                @* JavaScript sẽ tự động tạo các nút danh mục ở đây *@
            </div>
        </div>

        @* ══════════ CỘT GIỮA: SẢN PHẨM ══════════ *@
        <div class="col-6 product-panel">
            <h5 class="mb-3">🍹 Menu</h5>
            <div id="product-list" class="row g-3">
                @* JavaScript sẽ tự động tạo các thẻ sản phẩm ở đây *@
            </div>
        </div>

        @* ══════════ CỘT PHẢI: GIỎ HÀNG & KHÁCH ══════════ *@
        <div class="col-4 cart-panel">

            @* --- Khu vực nhập SĐT Khách hàng --- *@
            <h5 class="mb-2">👤 Khách hàng</h5>
            <!-- <div class="mb-3">
                <input type="text" id="customer-phone" class="form-control bg-dark text-light border-secondary" 
                       placeholder="Nhập SĐT khách hàng..." oninput="checkCustomerPhone()" maxlength="10" />
                
                <div id="customer-info-box" class="d-none mt-2 p-2 rounded" style="background-color: #3d2a1c;">
                    <div class="d-flex justify-content-between align-items-center">
                        <span id="customer-info" class="text-light fw-bold fs-6"></span>
                        <span class="text-secondary small">Điểm: <span id="customer-points" class="text-warning fw-bold fs-6">0</span></span>
                    </div>
                    <div class="mt-2 input-group input-group-sm">
                        <span class="input-group-text bg-secondary text-light border-secondary px-2">Dùng điểm</span>
                        <input type="number" id="use-points" class="form-control bg-dark text-light border-secondary text-end" placeholder="0" min="0" oninput="updateTotal()">
                        <span class="input-group-text bg-secondary text-light border-secondary px-2">₫</span>
                    </div>
                </div>

                <small id="customer-not-found" class="text-secondary mt-1 d-block">
                    Nhập đủ 10 số để tìm khách hàng
                </small>
            </div> -->
            <div class="mb-3">
                <div class="input-group">
                    <input type="text"
                        id="customer-phone"
                        class="form-control bg-dark text-light border-secondary"
                        placeholder="Nhập SĐT khách hàng..."
                        maxlength="10" />
                    <button class="btn btn-outline-light"
                            type="button"
                            onclick="checkCustomerPhone()">
                        Kiểm tra
                    </button>
                </div>

                <div id="customer-info-box" class="d-none mt-2 p-2 rounded" style="background-color: #3d2a1c;">
                    <div class="d-flex justify-content-between align-items-center">
                        <span id="customer-info" class="text-light fw-bold fs-6"></span>
                        <span class="text-secondary small">Điểm: <span id="customer-points" class="text-warning fw-bold fs-6">0</span></span>
                    </div>
                    <div class="mt-2 input-group input-group-sm">
                        <span class="input-group-text bg-secondary text-light border-secondary px-2">Dùng điểm</span>
                        <input type="number" id="use-points"
                            class="form-control bg-dark text-light border-secondary text-end"
                            placeholder="0" min="0"
                            oninput="updateTotal()">
                        <span class="input-group-text bg-secondary text-light border-secondary px-2">₫</span>
                    </div>
                </div>

                <small id="customer-not-found" class="text-secondary mt-1 d-block">
                    Nhập SĐT và bấm "Kiểm tra" để tìm khách hàng
                </small>
            </div>

            @* --- Loại Đơn Hàng (Tại chỗ/Mang đi) --- *@
            <h5 class="mb-2 mt-3">🍽️ Loại đơn</h5>
            <div class="mb-3 d-flex gap-4">
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="orderType" id="typeEatIn" value="EatIn" checked>
                    <label class="form-check-label" for="typeEatIn">Tại chỗ</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="orderType" id="typeTakeAway" value="TakeAway">
                    <label class="form-check-label" for="typeTakeAway">Mang đi</label>
                </div>
            </div>

            @* --- Danh sách giỏ hàng --- *@
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">🛒 Giỏ hàng</h5>
                <button class="btn btn-sm btn-outline-danger" onclick="clearCart()">🗑 Xóa hết</button>
            </div>
            <div id="cart-items" style="flex: 1; overflow-y: auto;">
                <p class="text-secondary text-center mt-4">Chưa có món nào</p>
            </div>

