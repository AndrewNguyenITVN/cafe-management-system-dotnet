        }
    }

    //Hàm load nhân viên
    async function loadCashiers() {
        const box = document.getElementById('cashier-list-box');
        if (!box) return;
        try {
            const res = await fetch('/Pos/GetCashiers', { credentials: 'same-origin' });
            if (!res.ok) {
                box.innerHTML = '<p class="text-danger text-center small py-3 mb-0">Lỗi tải danh sách (HTTP ' + res.status + ')</p>';
                return;
            }
            const data = await res.json();

            // Backend có thể trả array hoặc object có property (tương thích cả PascalCase/camelCase)
            const list = Array.isArray(data) ? data : (data.data || data.items || []);
            if (list.length === 0) {
                box.innerHTML = '<p class="text-secondary text-center small py-3 mb-0">Chưa có nhân viên</p>';
                return;
            }

            box.innerHTML = '';
            list.forEach(c => {
                const id = c.id ?? c.Id ?? '';
                const name = (c.name ?? c.Name ?? '').trim() || 'Nhân viên';
                const div = document.createElement('div');
                div.className = 'cashier-item px-3 py-2 text-dark border-bottom';
                div.style.cursor = 'pointer';
                div.dataset.id = id;
                div.dataset.name = name;
                div.textContent = name;

                div.onclick = function () {
                    document.querySelectorAll('#cashier-list-box .cashier-item').forEach(el => {
                        el.classList.remove('selected', 'bg-primary', 'text-white');
                        el.classList.add('text-dark');
                    });
                    this.classList.add('selected', 'bg-primary', 'text-white');
                    this.classList.remove('text-dark');
                    selectedCashierId = this.dataset.id;
                };

                box.appendChild(div);
            });
        } catch (e) {
            console.error('Lỗi load danh sách nhân viên:', e);
            box.innerHTML = '<p class="text-danger text-center small py-3 mb-0">Lỗi tải danh sách</p>';
        }
    }

    // Cài đặt SignalR cho Màn hình Thu Ngân để nhận thông báo Hủy đơn
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/orderHub")
        .withAutomaticReconnect()
        .build();

    connection.on("OrderCancelled", function (data) {
        // Mở popup Cảnh báo Hủy Đơn
        const box = document.getElementById('order-cancelled-box');
        if (box) {
            document.getElementById('cancelled-queue-number').textContent = "#" + data.queueNumber;
            document.getElementById('cancelled-reason').textContent = data.reason;
            
            box.classList.remove('d-none');
            box.classList.add('d-flex');
        }
    });

    // Gọi hàm load nhân viên ngay khi DOM bắt đầu
    function initPos() {
        loadCashiers();
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initPos);
    } else {
        initPos();
    }

