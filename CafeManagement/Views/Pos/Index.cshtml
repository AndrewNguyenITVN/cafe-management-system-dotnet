@* Trang POS không dùng chung Layout Admin *@
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>POS - Máy Thu Ngân</title>

    @* Bootstrap CSS *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    @* Custom CSS *@
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap');

        /* ===== TOÀN TRANG ===== */
        body {
            background-color: #f8f9fa;  /* Nền sáng */
            color: #212529;             /* Chữ đen */
            font-family: 'Outfit', sans-serif;
            overflow: hidden;           /* Giữ layout POS 1 màn hình, không cuộn toàn trang */
            height: 100vh;              /* Chiếm hết chiều cao màn hình */
        }

        /* ===== CỘT TRÁI - DANH MỤC ===== */
        .category-panel {
            background-color: #ffffff;  /* Nền trắng */
            height: 100vh;
            padding: 20px 15px;
            overflow-y: auto;           /* Cuộn được nếu danh mục nhiều */
            border-right: 1px solid #dee2e6;
        }
        .category-btn {
            display: block;
            width: 100%;
            padding: 16px;
            margin-bottom: 12px;
            border: 1px solid #dee2e6;
            border-radius: 12px;
            background-color: #ffffff;
            color: #212529;
            font-size: 16px;
            font-weight: 600;
            text-align: left;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .category-btn::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 4px; height: 100%;
            background-color: #0d6efd; /* Caramel highlight */
            transform: scaleY(0);
            transition: transform 0.3s;
        }
        .category-btn:hover {
            background-color: #e9ecef;
            transform: translateX(4px);
        }
        .category-btn.active {
            background-color: #e9ecef;  
            color: #000;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .category-btn.active::before {
            transform: scaleY(1);
        }

        /* ===== CỘT GIỮA - SẢN PHẨM ===== */
        .product-panel {
            height: 100vh;
            padding: 24px;
            overflow-y: auto;
            background-color: #f8f9fa;
        }
        .product-card {
            background: #ffffff;
            border: 1px solid #dee2e6;
            border-radius: 16px;
            padding: 20px 16px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            position: relative;
            overflow: hidden;
        }
        .product-card::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; width: 100%; height: 2px;
            background: #0d6efd;
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        .product-card:hover {
            transform: translateY(-5px);      
            border-color: #0d6efd;
            box-shadow: 0 8px 15px rgba(0,0,0,0.1);
        }
        .product-card:hover::after {
            transform: scaleX(1);
        }
        .product-card .name {
            font-weight: 700;
            margin-top: 12px;
            font-size: 15px;
            letter-spacing: 0.5px;
        }
        .product-card .price {
            color: #0d6efd;
            font-weight: bold;
            font-size: 18px;
            margin-top: 6px;
        }

        /* ===== CỘT PHẢI - GIỎ HÀNG ===== */
        .cart-panel {
            background-color: #ffffff;
            height: 100vh;
            padding: 20px 24px;
            border-left: 1px solid #dee2e6;
            box-shadow: -4px 0 15px rgba(0,0,0,0.05);
            overflow-y: auto;            /* Chỉ riêng cột phải được cuộn */
        }
        .cart-item {
            background-color: #ffffff;
            border-radius: 12px;
            padding: 12px 16px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 3px solid #0d6efd;
            transition: background 0.2s;
        }
        .cart-item:hover { background-color: #e9ecef; }
        .cart-item .qty-btn {
            background: #e9ecef;
            color: #212529;
            border: none;
            border-radius: 6px;
            width: 28px;
            height: 28px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s;
        }
        .cart-item .qty-btn:hover {
            background: #0d6efd;
            color: #ffffff;
        }
        .cart-item .item-details { flex-grow: 1; margin: 0 10px; }
        .cart-item .name { font-weight: 600; font-size: 15px; }
        .cart-item .price { color: #0d6efd; font-size: 14px; margin-top: 2px; }

        .cart-summary {
            margin-top: auto;  /* Đẩy phần tổng tiền xuống cuối cột */
            background-color: #ffffff;
            padding: 20px;
            border-radius: 16px;
            border: 1px solid #dee2e6;
        }
        .btn-checkout {
            background: #0d6efd;
            color: #ffffff;
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 12px;
            font-size: 18px;
            font-weight: 800;
            letter-spacing: 1px;
            margin-top: 15px;
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(13,110,253,0.3);
        }
        .btn-checkout:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(13,110,253,0.4);
        }

        /* Nút chọn phương thức thanh toán */
        .payment-method-group {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        .payment-method-btn {
            flex: 1 1 45%;
            padding: 10px 12px;
            border-radius: 999px;
            border: 1px solid #dee2e6;
            background-color: #ffffff;
            color: #212529;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            text-align: center;
        }
        .payment-method-btn:hover {
            background-color: #e9ecef;
        }
        .payment-method-btn.active {
            background: #0d6efd;
            color: #ffffff;
            border-color: #0d6efd;
            box-shadow: 0 0 10px rgba(13,110,253,0.5);
        }

        /* ETC button and overlay */
        .etc-button {
            position: fixed;
            bottom: 20px;
            left: 20px;
            z-index: 1030;
            background-color: #ffffff;
            border: 1px solid #0d6efd;
            color: #212529;
            border-radius: 999px;
            padding: 8px 16px;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        .etc-button:hover {
            background-color: #e9ecef;
        }
        #etc-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1040;
        }
        .etc-panel {
            max-width: 520px;
            background-color: #ffffff;
            border-radius: 16px;
            border: 1px solid #0d6efd;
            box-shadow: 0 12px 40px rgba(0,0,0,0.15);
            padding: 24px 24px 18px;
        }
        .etc-action-btn {
            width: 100%;
            padding: 10px 12px;
            border-radius: 10px;
            border: 1px solid #dee2e6;
            background-color: #ffffff;
            color: #212529;
            font-weight: 600;
            text-align: left;
            cursor: pointer;
            margin-bottom: 8px;
        }
        .etc-action-btn:hover {
            background-color: #e9ecef;
        }
        
        /* Tùy chỉnh thanh cuộn dải mỏng */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #1a120b; }
        ::-webkit-scrollbar-thumb { background: #3d2a1c; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #0d6efd; }
        
        /* Tùy chỉnh input cho đẹp */
        .form-control.bg-dark {
            background-color: #1a120b !important;
            border-color: #dee2e6 !important;
            color: #f7e6c4 !important;
            padding: 12px;
            border-radius: 8px;
        }
        .form-control.bg-dark:focus {
            box-shadow: 0 0 0 0.25rem rgba(212, 163, 115, 0.25);
            border-color: #d4a373 !important;
        }
        .form-check-input:checked {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }

        #cashier-list-box .cashier-item {
            padding: 12px 14px;
            border-bottom: 1px solid #dee2e6;
            cursor: pointer;
            color: #212529;
            transition: background 0.2s;
        }
        #cashier-list-box .cashier-item:hover {
            background-color: #ffffff;
        }
        #cashier-list-box .cashier-item.selected {
            background-color: #e9ecef;
            border-left: 4px solid #0d6efd;
        }
        #cashier-list-box .cashier-item:last-child {
            border-bottom: none;
        }
    </style>
</head>

<body>

@* ══════════ MÀN HÌNH KHÓA PIN ══════════ *@
<div id="pin-overlay" class="position-fixed top-0 start-0 w-100 h-100 d-flex flex-column justify-content-center align-items-center" style="background-color: #ffffff; z-index: 9999;">
    <h2 class="mb-4 fw-bold" style="color: #0d6efd;">🔒 MỞ CA LÀM VIỆC</h2>
    <!-- Chọn nhân viên -->
    <div class="mb-3" style="width: 280px;">
        <label class="form-label small text-secondary mb-1">Chọn nhân viên</label>
        <div id="cashier-list-box" class="border rounded overflow-y-auto bg-light"
            style="max-height: 200px; border-color: #dee2e6 !important;">
            <p class="text-secondary text-center small py-3 mb-0">Đang tải...</p>
        </div>
    </div>
    <input type="password" id="pin-input" class="form-control bg-white text-center text-dark fs-3 mb-4 rounded-3 border-secondary" style="width: 250px; letter-spacing: 10px; height: 60px;" readonly />
    <div class="d-grid gap-2" style="grid-template-columns: repeat(3, 1fr); width: 250px;">
        <button class="btn btn-outline-dark fs-4 py-2" onclick="addPin('1')">1</button>
        <button class="btn btn-outline-dark fs-4 py-2" onclick="addPin('2')">2</button>
        <button class="btn btn-outline-dark fs-4 py-2" onclick="addPin('3')">3</button>
        <button class="btn btn-outline-dark fs-4 py-2" onclick="addPin('4')">4</button>
        <button class="btn btn-outline-dark fs-4 py-2" onclick="addPin('5')">5</button>
        <button class="btn btn-outline-dark fs-4 py-2" onclick="addPin('6')">6</button>
        <button class="btn btn-outline-dark fs-4 py-2" onclick="addPin('7')">7</button>
        <button class="btn btn-outline-dark fs-4 py-2" onclick="addPin('8')">8</button>
        <button class="btn btn-outline-dark fs-4 py-2" onclick="addPin('9')">9</button>
        <button class="btn btn-danger fs-4 py-2 fw-bold text-white" onclick="clearPin()">C</button>
        <button class="btn btn-outline-dark fs-4 py-2" onclick="addPin('0')">0</button>
        <button class="btn btn-success fs-4 py-2 fw-bold text-white" onclick="submitPin()">OK</button>
    </div>
    <span id="pin-error" class="text-danger mt-3 d-none fw-bold fs-5">Mã PIN không đúng!</span>

    @* Box thông báo khi nhập sai PIN *@
    <div id="pin-error-box" class="position-fixed top-0 start-0 w-100 h-100 d-none align-items-center justify-content-center" style="background: rgba(0,0,0,0.6); z-index: 10000;">
        <div class="bg-white border rounded-3 shadow-lg p-4 text-center" style="max-width: 320px; border-color: #dee2e6 !important;">
            <div class="mb-3 fs-1">⚠️</div>
            <h5 class="text-primary mb-2">Mã PIN không đúng</h5>
            <p id="pin-error-box-message" class="text-secondary small mb-4">Vui lòng kiểm tra lại mã PIN và thử lại.</p>
            <button type="button" class="btn btn-outline-dark px-4" onclick="closePinErrorBox()">Đóng</button>
        </div>
    </div>
</div>

@* Box thông báo Đặt Hàng Thành Công Popup *@
<div id="order-success-box" class="position-fixed top-0 start-0 w-100 h-100 d-none align-items-center justify-content-center" style="background: rgba(0,0,0,0.5); z-index: 10000;">
    <div class="bg-white border rounded-4 shadow-lg p-5 text-center" style="max-width: 450px; border-color: #dee2e6 !important; position: relative;">
        <!-- Icon Success Animation -->
        <div class="mb-3 d-flex justify-content-center">
            <div class="rounded-circle d-flex align-items-center justify-content-center text-success" 
                 style="width: 110px; height: 110px; background: rgba(13, 110, 253, 0.2); border: 4px solid #0d6efd; font-size: 5rem; animation: bounceIn 0.5s ease;">
                ✓
            </div>
        </div>
        <h3 class="text-dark mb-2 fw-bold" style="color: #212529 !important;">ĐẶT HÀNG THÀNH CÔNG!</h3>
        <p class="text-secondary fs-5 mb-4">Số thứ tự của khách: <span id="success-queue-number" class="text-primary fw-bold fs-2 ms-2">#0</span></p>
        
        <button type="button" class="btn w-100 fs-4 py-3 fw-bold shadow" 
                style="background: #0d6efd; color:#ffffff; border-radius: 12px; transition: transform 0.2s;"
                onclick="closeOrderSuccessBox()">
            Tiếp Tục Bán Hàng ❯
        </button>
    </div>
</div>

@* Box Cảnh báo Bếp HỦY ĐƠN *@
<div id="order-cancelled-box" class="position-fixed top-0 start-0 w-100 h-100 d-none align-items-center justify-content-center" style="background: rgba(0,0,0,0.5); z-index: 10000;">
    <div class="bg-white border rounded-4 shadow-lg p-5 text-center" style="max-width: 450px; border-color: #e07a5f !important; position: relative;">
        <!-- Icon Alert Animation -->
        <div class="mb-3 d-flex justify-content-center">
            <div class="rounded-circle d-flex align-items-center justify-content-center text-danger" 
                 style="width: 110px; height: 110px; background: rgba(224, 122, 95, 0.2); border: 4px solid #e07a5f; font-size: 5rem; animation: bounceIn 0.5s ease;">
                !
            </div>
        </div>
        <h3 class="text-danger mb-2 fw-bold">BẾP VỪA HỦY ĐƠN</h3>
        <p class="text-secondary fs-5 mb-2">Đơn STT: <span id="cancelled-queue-number" class="text-primary fw-bold fs-3 ms-2">#0</span></p>
        <p class="text-dark fs-5 mb-4 bg-light p-3 rounded" style="background-color: #ffffff !important;">Lý do: <br><strong id="cancelled-reason" style="color: #0d6efd;">Nguyên liệu</strong></p>
        
        <button type="button" class="btn btn-outline-danger w-100 fs-5 py-2 fw-bold" 
                onclick="closeOrderCancelledBox()">
            Đã rõ
        </button>
    </div>
</div>

@* Layout 3 cột (Grid Bootstrap) *@

<div class="container-fluid">
    <div class="row">

        @* ══════════ CỘT TRÁI: DANH MỤC ══════════ *@
        <div class="col-2 category-panel">
            <h5 class="mb-3">📋 Danh mục</h5>
            <div id="category-list">
                @* JavaScript sẽ tự động tạo các nút danh mục ở đây *@
            </div>
        </div>

        @* ══════════ CỘT GIỮA: SẢN PHẨM ══════════ *@
        <div class="col-6 product-panel">
            <h5 class="mb-3">🍹 Menu</h5>
            <div id="product-list" class="row g-3">
                @* JavaScript sẽ tự động tạo các thẻ sản phẩm ở đây *@
            </div>
        </div>

        @* ══════════ CỘT PHẢI: GIỎ HÀNG & KHÁCH ══════════ *@
        <div class="col-4 cart-panel">

            @* --- Khu vực nhập SĐT Khách hàng --- *@
            <h5 class="mb-2">👤 Khách hàng</h5>
            <!-- <div class="mb-3">
                <input type="text" id="customer-phone" class="form-control bg-white text-dark border-secondary" 
                       placeholder="Nhập SĐT khách hàng..." oninput="checkCustomerPhone()" maxlength="10" />
                
                <div id="customer-info-box" class="d-none mt-2 p-2 rounded" style="background-color: #ffffff;">
                    <div class="d-flex justify-content-between align-items-center">
                        <span id="customer-info" class="text-dark fw-bold fs-6"></span>
                        <span class="text-secondary small">Điểm: <span id="customer-points" class="text-primary fw-bold fs-6">0</span></span>
                    </div>
                    <div class="mt-2 input-group input-group-sm">
                        <span class="input-group-text bg-light text-dark border-secondary px-2">Dùng điểm</span>
                        <input type="number" id="use-points" class="form-control bg-white text-dark border-secondary text-end" placeholder="0" min="0" oninput="updateTotal()">
                        <span class="input-group-text bg-light text-dark border-secondary px-2">₫</span>
                    </div>
                </div>

                <small id="customer-not-found" class="text-secondary mt-1 d-block">
                    Nhập đủ 10 số để tìm khách hàng
                </small>
            </div> -->
            <div class="mb-3">
                <div class="input-group">
                    <input type="text"
                        id="customer-phone"
                        class="form-control bg-white text-dark border-secondary"
                        placeholder="Nhập SĐT khách hàng..."
                        maxlength="10" />
                    <button class="btn btn-outline-dark"
                            type="button"
                            onclick="checkCustomerPhone()">
                        Kiểm tra
                    </button>
                </div>

                <div id="customer-info-box" class="d-none mt-2 p-2 rounded" style="background-color: #ffffff;">
                    <div class="d-flex justify-content-between align-items-center">
                        <span id="customer-info" class="text-dark fw-bold fs-6"></span>
                        <span class="text-secondary small">Điểm: <span id="customer-points" class="text-primary fw-bold fs-6">0</span></span>
                    </div>
                    <div class="mt-2 input-group input-group-sm">
                        <span class="input-group-text bg-light text-dark border-secondary px-2">Dùng điểm</span>
                        <input type="number" id="use-points"
                            class="form-control bg-white text-dark border-secondary text-end"
                            placeholder="0" min="0"
                            oninput="updateTotal()">
                        <span class="input-group-text bg-light text-dark border-secondary px-2">₫</span>
                    </div>
                </div>

                <small id="customer-not-found" class="text-secondary mt-1 d-block">
                    Nhập SĐT và bấm "Kiểm tra" để tìm khách hàng
                </small>
            </div>

            @* --- Loại Đơn Hàng (Tại chỗ/Mang đi) --- *@
            <h5 class="mb-2 mt-3">🍽️ Loại đơn</h5>
            <div class="mb-3 d-flex gap-4">
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="orderType" id="typeEatIn" value="EatIn" checked>
                    <label class="form-check-label" for="typeEatIn">Tại chỗ</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="orderType" id="typeTakeAway" value="TakeAway">
                    <label class="form-check-label" for="typeTakeAway">Mang đi</label>
                </div>
            </div>

            @* --- Danh sách giỏ hàng --- *@
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">🛒 Giỏ hàng</h5>
                <button class="btn btn-sm btn-outline-danger" onclick="clearCart()">🗑 Xóa hết</button>
            </div>
            <div id="cart-items">
                <p class="text-secondary text-center mt-4">Chưa có món nào</p>
            </div>

            @* --- Tổng tiền & Nút thanh toán --- *@
            <div class="cart-summary">
                <div class="d-flex justify-content-between mb-1">
                    <span>Tổng tiền:</span>
                    <span id="total-amount" class="fw-bold" style="color: #e94560;">0 ₫</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span>Điểm sử dụng:</span>
                    <span id="points-used">0 ₫</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="fw-bold fs-5">Thành tiền:</span>
                    <span id="final-amount" class="fw-bold fs-5" style="color: #e94560;">0 ₫</span>
                </div>
                @* --- Phương thức thanh toán (Branch 3 - TV5) --- *@
                <h5 class="mb-2 mt-3">💳 Phương thức thanh toán</h5>
                <div id="payment-method-group" class="payment-method-group mb-2">
                    @* JavaScript sẽ render các nút phương thức thanh toán tại đây *@
                </div>
                <div id="cash-tendered-row" class="mb-2 d-none">
                    <label class="form-label small text-secondary mb-0">Tiền khách đưa</label>
                    <input type="number" id="amount-tendered" class="form-control bg-white text-dark border-secondary text-end" placeholder="0" min="0" value="0" oninput="updateChangeDisplay()">
                </div>
                <div id="change-row" class="d-flex justify-content-between mb-3 d-none">
                    <span>Tiền thối:</span>
                    <span id="change-amount" class="fw-bold" style="color: #0d6efd;">0 ₫</span>
                </div>
                <button class="btn-checkout" onclick="checkout()">
                    💳 HOÀN TẤT THANH TOÁN
                </button>
            </div>
        </div>

    </div>
</div>

<button type="button" class="etc-button" onclick="openEtcOverlay()">
    ⚙️ ETC
</button>

<div id="etc-overlay" class="d-none align-items-center justify-content-center">
    <div class="etc-panel">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold" style="color:#d4a373;">⚙️ Tùy chọn nâng cao</h5>
            <button type="button" class="btn btn-sm btn-outline-dark" onclick="closeEtcOverlay()">Đóng</button>
        </div>

        <div id="etc-main-menu">
            <button type="button" class="etc-action-btn" onclick="openCloseShiftPanel()">
                💰 Kết ca thu ngân
            </button>
            <button type="button" class="etc-action-btn" onclick="showFeatureWip('Báo cáo nhanh')">
                📊 Báo cáo nhanh (đang phát triển)
            </button>
            <button type="button" class="etc-action-btn" onclick="showFeatureWip('Cấu hình máy')">
                🛠️ Cấu hình máy (đang phát triển)
            </button>
        </div>

        <div id="etc-close-shift-panel" class="d-none">
            <h6 class="fw-bold mb-2" style="color:#d4a373;">💰 Kết ca thu ngân</h6>
            <div class="small text-secondary mb-2" id="close-shift-store-label"></div>
            <div class="row g-2 mb-2">
                <div class="col-6">
                    <label class="form-label form-label-sm">Ca làm việc</label>
                    <select id="cs-shiftId" class="form-select form-select-sm">
                        <option value="1">Ca Sáng (06:00 - 12:00)</option>
                        <option value="2">Ca Chiều (12:00 - 18:00)</option>
                        <option value="3">Ca Tối (18:00 - 00:00)</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label form-label-sm">Ngày</label>
                    <input id="cs-date" type="date" class="form-control form-control-sm" />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-6">
                    <label class="form-label form-label-sm">Doanh thu ca</label>
                    <input id="cs-totalRevenue" class="form-control form-control-sm" readonly value="0 ₫" />
                </div>
                <div class="col-6">
                    <label class="form-label form-label-sm">Tiền mặt (máy)</label>
                    <input id="cs-totalCash" class="form-control form-control-sm" readonly value="0 ₫" />
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-4">
                    <label class="form-label form-label-sm">Tiền đầu ca</label>
                    <input id="cs-openingCash" type="number" class="form-control form-control-sm" value="0" min="0" />
                </div>
                <div class="col-4">
                    <label class="form-label form-label-sm">Thực tế</label>
                    <input id="cs-actualCash" type="number" class="form-control form-control-sm" value="0" min="0" />
                </div>
                <div class="col-4">
                    <label class="form-label form-label-sm">Lý thuyết</label>
                    <input id="cs-expectedCash" class="form-control form-control-sm" readonly value="0 ₫" />
                </div>
            </div>

            <div class="mb-2">
                <label class="form-label form-label-sm">Chênh lệch</label>
                <input id="cs-difference" class="form-control form-control-sm fw-bold" readonly value="0 ₫" />
            </div>

            <div class="mb-2">
                <label class="form-label form-label-sm">Ghi chú (bắt buộc nếu có chênh lệch)</label>
                <textarea id="cs-note" class="form-control form-control-sm" rows="2"></textarea>
            </div>

            <div class="d-flex justify-content-between mt-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="backToEtcMenu()">⬅ Quay lại</button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-dark" onclick="loadCloseShiftPreview()">🔄 Tính lại</button>
                    <button type="button" class="btn btn-sm btn-primary" onclick="submitCloseShift()">✅ Kết ca</button>
                </div>
            </div>
        </div>
    </div>
</div>

@* JAVASCRIPT LOGIC *@
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>

    // 1. Biến toàn cục

    let categories = [];   
    let products = [];     
    let cart = [];         
    let maxPoints = 0;     // Số điểm tối đa khách có thể dùng

    let currentPin = "";
    let activeCashierId = "";
    let activeCashierName = "";
    let currentStoreId = 1;
    let selectedCashierId = "";      // id nhân viên đang chọn (để gửi kèm PIN)
    let paymentMethods = [];         // Danh sách phương thức thanh toán (id, name)
    let selectedPaymentMethodId = 0; // Id phương thức thanh toán đang chọn

    // 2. Fetch dữ liệu API

    // Hàm load danh mục từ Database
    async function loadCategories() {
        try {
            // fetch() gửi GET Request tới URL /Pos/GetCategories
            // Server C# (PosController.GetCategories) sẽ truy vấn DB và trả JSON
            const response = await fetch('/Pos/GetCategories');
            categories = await response.json();  // Ép kết quả thành mảng JS

            renderCategories();  // Vẽ lên giao diện

            // Tự động chọn danh mục đầu tiên (nếu có)
            if (categories.length > 0) {
                document.querySelector('.category-btn').classList.add('active');
                loadProducts(categories[0].id);
            }
            loadPaymentMethods();
        } catch (error) {
            console.error('❌ Lỗi load danh mục:', error);
            // NẾU LỖI (VD: DB chưa có dữ liệu) → dùng dữ liệu mẫu tạm
            categories = [
                { id: 1, name: "☕ Cà phê (Demo)" },
                { id: 2, name: "🧋 Trà sữa (Demo)" },
            ];
            renderCategories();
            document.querySelector('.category-btn')?.classList.add('active');
            loadPaymentMethods();
        }
    }

    // Hàm load phương thức thanh toán (Tiền mặt, Chuyển khoản...)
    async function loadPaymentMethods() {
        try {
            const res = await fetch('/Pos/GetPaymentMethods');
            paymentMethods = await res.json();
            const group = document.getElementById('payment-method-group');
            if (!group) return;
            group.innerHTML = '';
            paymentMethods.forEach(p => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'payment-method-btn';
                btn.dataset.id = p.id;
                btn.textContent = p.name;
                btn.onclick = () => selectPaymentMethod(p.id);
                group.appendChild(btn);
            });
        } catch (e) {
            console.error('Lỗi load phương thức thanh toán:', e);
        }
    }

    // ETC overlay logic
    function openEtcOverlay() {
        const overlay = document.getElementById('etc-overlay');
        if (!overlay) return;
        overlay.classList.remove('d-none');
        overlay.classList.add('d-flex');

        document.getElementById('etc-main-menu').classList.remove('d-none');
        document.getElementById('etc-close-shift-panel').classList.add('d-none');

        const dateInput = document.getElementById('cs-date');
        if (dateInput) {
            const today = new Date().toISOString().slice(0, 10);
            dateInput.value = today;
        }
    }

    function closeEtcOverlay() {
        const overlay = document.getElementById('etc-overlay');
        if (!overlay) return;
        overlay.classList.add('d-none');
        overlay.classList.remove('d-flex');
    }

    function showFeatureWip(name) {
        alert('Tính năng "' + name + '" đang được triển khai.');
    }

    function openCloseShiftPanel() {
        document.getElementById('etc-main-menu').classList.add('d-none');
        document.getElementById('etc-close-shift-panel').classList.remove('d-none');
        document.getElementById('close-shift-store-label').textContent =
            'Chi nhánh hiện tại sẽ được dùng để tính ca (theo tài khoản đăng nhập).';
        loadCloseShiftPreview();
    }

    function backToEtcMenu() {
        document.getElementById('etc-main-menu').classList.remove('d-none');
        document.getElementById('etc-close-shift-panel').classList.add('d-none');
    }

    // Parse chuỗi tiền VN: "129.600 ₫" → 129600 (dấu chấm là phân cách hàng nghìn, không phải thập phân).
    function parseMoneyInput(value) {
        const s = (value || '0').toString().trim().replace(/\s*₫\s*/g, '');
        if (!s) return 0;
        // Có dấu phẩy → coi là thập phân (VN: 129,5)
        if (s.includes(',')) {
            const normalized = s.replace(/\./g, '').replace(',', '.');
            return parseFloat(normalized) || 0;
        }
        // Chỉ có dấu chấm: nếu phần sau dấu chấm cuối có 3 chữ số → dấu chấm là nghìn (129.600 → 129600).
        const parts = s.split('.');
        if (parts.length > 1 && parts[parts.length - 1].length === 3 && /^\d+$/.test(parts[parts.length - 1])) {
            return parseFloat(s.replace(/\./g, '')) || 0;
        }
        return parseFloat(s) || 0;
    }

    async function loadCloseShiftPreview() {
        const shiftId = parseInt(document.getElementById('cs-shiftId').value || '1', 10);
        const dateStr = document.getElementById('cs-date').value;
        if (!dateStr) return;

        const url = `/Pos/GetShiftHandoverPreview?shiftId=${shiftId}&date=${dateStr}`;
        const res = await fetch(url);
        if (!res.ok) {
            const text = await res.text();
            console.error('Preview error:', text);
            alert('Không thể tải dữ liệu kết ca (mã ' + res.status + ').');
            return;
        }
        const data = await res.json();
        if (!data.success) {
            alert(data.message || 'Không thể tải dữ liệu kết ca.');
            return;
        }

        document.getElementById('cs-totalRevenue').value = formatMoney(parseMoneyInput(data.totalRevenue));
        document.getElementById('cs-totalCash').value = formatMoney(parseMoneyInput(data.totalCash));

        recalcCloseShiftExpectedAndDiff();
    }

    function recalcCloseShiftExpectedAndDiff() {
        const totalCash = parseMoneyInput(document.getElementById('cs-totalCash').value);
        const openingCash = parseFloat(document.getElementById('cs-openingCash').value || '0');
        const actualCash = parseFloat(document.getElementById('cs-actualCash').value || '0');

        const expected = openingCash + totalCash;
        const diff = actualCash - expected;

        document.getElementById('cs-expectedCash').value = formatMoney(expected);

        const diffInput = document.getElementById('cs-difference');
        diffInput.value = formatMoney(diff);
        diffInput.classList.remove('text-danger', 'text-success');
        if (diff < 0) diffInput.classList.add('text-danger');
        if (diff > 0) diffInput.classList.add('text-success');
    }

    document.getElementById('cs-openingCash').addEventListener('input', recalcCloseShiftExpectedAndDiff);
    document.getElementById('cs-actualCash').addEventListener('input', recalcCloseShiftExpectedAndDiff);

    async function submitCloseShift() {
        const shiftId = parseInt(document.getElementById('cs-shiftId').value || '1', 10);
        const dateStr = document.getElementById('cs-date').value;
        if (!dateStr) {
            alert('Vui lòng chọn ngày kết ca.');
            return;
        }

        const openingCash = parseFloat(document.getElementById('cs-openingCash').value || '0');
        const actualCash = parseFloat(document.getElementById('cs-actualCash').value || '0');
        const totalCash = parseMoneyInput(document.getElementById('cs-totalCash').value);
        const expected = openingCash + totalCash;
        const diff = actualCash - expected;

        const note = (document.getElementById('cs-note').value || '').trim();
        if (diff !== 0 && !note) {
            alert('Có chênh lệch tiền mặt, vui lòng nhập ghi chú lý do.');
            return;
        }

        if (!confirm('Xác nhận kết ca cho ngày ' + dateStr + ' ?')) {
            return;
        }

        const payload = {
            shiftId,
            date: dateStr,
            openingCash,
            actualCashCounted: actualCash,
            note
        };

        const res = await fetch('/Pos/SubmitShiftHandover', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        if (!res.ok) {
            const text = await res.text();
            console.error('Submit close shift error:', text);
            alert('Kết ca thất bại (mã ' + res.status + ').');
            return;
        }
        const data = await res.json();
        if (!data.success) {
            alert(data.message || 'Kết ca thất bại.');
            return;
        }

        alert('✅ Đã kết ca thành công.\nChênh lệch: ' + formatMoney(data.difference));
        // Reload về màn hình PIN
        window.location.reload();
    }

    function isCashMethod(id) {
        const method = paymentMethods.find(p => p.id === id);
        if (!method) return false;
        const name = (method.name || '').toLowerCase();
        return id === 1 || name.includes('tiền mặt');
    }

    function selectPaymentMethod(id) {
        selectedPaymentMethodId = id;
        const group = document.getElementById('payment-method-group');
        if (group) {
            group.querySelectorAll('.payment-method-btn').forEach(btn => {
                btn.classList.toggle('active', parseInt(btn.dataset.id, 10) === id);
            });
        }

        const cashRow = document.getElementById('cash-tendered-row');
        const changeRow = document.getElementById('change-row');
        const amountInput = document.getElementById('amount-tendered');
        if (isCashMethod(id)) {
            cashRow.classList.remove('d-none');
            changeRow.classList.remove('d-none');
            amountInput.value = '';
            updateChangeDisplay();
        } else {
            cashRow.classList.add('d-none');
            changeRow.classList.add('d-none');
            amountInput.value = '0';
        }
    }

    function updateChangeDisplay() {
        const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
        const usedPoints = parseInt(document.getElementById('use-points')?.value || 0, 10);
        const finalAmount = Math.max(total - Math.min(usedPoints, maxPoints), 0);
        const amountInput = document.getElementById('amount-tendered');
        const changeLabel = document.getElementById('change-amount');
        if (!amountInput || !changeLabel || !isCashMethod(selectedPaymentMethodId)) {
            if (changeLabel) changeLabel.textContent = formatMoney(0);
            return;
        }
        const tendered = parseFloat(amountInput.value || 0, 10) || 0;
        const change = Math.max(tendered - finalAmount, 0);
        changeLabel.textContent = formatMoney(change);
    }

    function resetAfterOrder() {
        // Reset giỏ hàng
        cart = [];
        renderCart();

        // Reset thông tin khách hàng
        const phoneInput = document.getElementById('customer-phone');
        if (phoneInput) phoneInput.value = '';

        const infoBox = document.getElementById('customer-info-box');
        const notFoundText = document.getElementById('customer-not-found');
        if (infoBox) infoBox.classList.add('d-none');
        if (notFoundText) {
            notFoundText.classList.remove('d-none');
            notFoundText.textContent = 'Nhập SĐT và bấm \"Kiểm tra\" để tìm khách hàng';
            notFoundText.style.color = '';
        }

        const usePointsInput = document.getElementById('use-points');
        if (usePointsInput) usePointsInput.value = 0;
        maxPoints = 0;

        // Reset phương thức thanh toán
        selectedPaymentMethodId = 0;
        const group = document.getElementById('payment-method-group');
        if (group) {
            group.querySelectorAll('.payment-method-btn').forEach(btn => btn.classList.remove('active'));
        }

        const amountInput = document.getElementById('amount-tendered');
        if (amountInput) amountInput.value = 0;
        const changeLabel = document.getElementById('change-amount');
        if (changeLabel) changeLabel.textContent = formatMoney(0);

        const cashRow = document.getElementById('cash-tendered-row');
        const changeRow = document.getElementById('change-row');
        if (cashRow) cashRow.classList.add('d-none');
        if (changeRow) changeRow.classList.add('d-none');

        // Tính lại tổng tiền (0) để đồng bộ UI
        updateTotal();
    }

    // Hàm load sản phẩm từ Database
    async function loadProducts(categoryId) {
        try {
            const response = await fetch('/Pos/GetMenuItems');
            products = await response.json();

            renderProducts(categoryId);  // Vẽ sản phẩm theo danh mục đang chọn
        } catch (error) {
            console.error('❌ Lỗi load sản phẩm:', error);
            products = [];
        }
    }


    // 3. Render danh mục

    function renderCategories() {
        const container = document.getElementById('category-list');
        container.innerHTML = '';

        categories.forEach(function (cat) {
            const btn = document.createElement('button');
            btn.className = 'category-btn';
            btn.textContent = cat.name;

            btn.onclick = function () {
                document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                // GỌI loadProducts thay vì renderProducts trực tiếp
                // Để đảm bảo luôn lấy dữ liệu mới nhất từ DB
                renderProducts(cat.id);
            };

            container.appendChild(btn);
        });
    }


    // 4. Render sản phẩm

    function renderProducts(categoryId) {
        const container = document.getElementById('product-list');
        container.innerHTML = '';

        const filtered = products.filter(p => p.categoryId === categoryId);

        if (filtered.length === 0) {
            container.innerHTML = '<p class="text-secondary text-center mt-5">Chưa có sản phẩm trong danh mục này</p>';
            return;
        }

        filtered.forEach(function (product) {
            const col = document.createElement('div');
            col.className = 'col-4';

            col.innerHTML = `
                <div class="product-card" onclick="addToCart(${product.id})">
                    <div class="name">${product.name}</div>
                    <div class="price">${formatMoney(product.price)}</div>
                </div>
            `;

            container.appendChild(col);
        });
    }


    // 5. Quản lý giỏ hàng

    function addToCart(productId) {
        const product = products.find(p => p.id === productId);
        if (!product) return;

        const existing = cart.find(item => item.id === productId);

        if (existing) {
            existing.quantity += 1;
        } else {
            cart.push({
                id: product.id,
                name: product.name,
                price: product.price,
                quantity: 1,
                note: ''
            });
        }

        renderCart();
    }

    function renderCart() {
        const container = document.getElementById('cart-items');

        if (cart.length === 0) {
            container.innerHTML = '<p class="text-secondary text-center mt-4">Chưa có món nào</p>';
            updateTotal();
            return;
        }

        let html = '';
        cart.forEach(function (item, index) {
            const safeNote = (item.note || '').replace(/"/g, '&quot;');
            html += `
                <div class="cart-item mb-2">
                    <div class="item-details">
                        <div class="name">${item.name}</div>
                        <div class="price">${formatMoney(item.price)}</div>
                    </div>
                    <div class="d-flex flex-column align-items-end gap-2" style="min-width: 140px;">
                        <div class="d-flex align-items-center gap-2">
                            <button class="qty-btn" onclick="changeQty(${index}, -1)">−</button>
                            <span class="fw-bold mx-1">${item.quantity}</span>
                            <button class="qty-btn" onclick="changeQty(${index}, +1)">+</button>
                            <span class="ms-2 price text-end" style="min-width: 80px;">
                                ${formatMoney(item.price * item.quantity)}
                            </span>
                        </div>
                        <input type="text"
                               class="form-control form-control-sm bg-white text-dark border-secondary"
                               placeholder="Ghi chú món này..."
                               value="${safeNote}"
                               oninput="updateItemNote(${index}, this.value)" />
                    </div>
                </div>
            `;
        });

        container.innerHTML = html;
        updateTotal();
    }

    function changeQty(index, delta) {
        cart[index].quantity += delta;
        if (cart[index].quantity <= 0) {
            cart.splice(index, 1);
        }
        renderCart();
    }

    function clearCart() {
        if (cart.length === 0) return;
        if (!confirm('Xóa toàn bộ giỏ hàng?')) return;
        cart = [];
        renderCart();
    }

    function updateItemNote(index, value) {
        if (!cart[index]) return;
        cart[index].note = value;
    }

    function updateTotal() {
        const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
        
        let usedPoints = parseInt(document.getElementById('use-points')?.value || 0, 10);
        
        // Validation: Không dùng quá số điểm đang có
        if (usedPoints > maxPoints) {
            usedPoints = maxPoints;
            document.getElementById('use-points').value = usedPoints;
        }
        
        // Validation: Không dùng quá giá trị đơn hàng
        if (usedPoints > total) {
            usedPoints = total;
            document.getElementById('use-points').value = usedPoints;
        }

        const finalAmount = Math.max(total - usedPoints, 0);

        document.getElementById('total-amount').textContent = formatMoney(total);
        document.getElementById('points-used').textContent = "-" + formatMoney(usedPoints);
        document.getElementById('final-amount').textContent = formatMoney(finalAmount);
        updateChangeDisplay();
    }


    // 6. Thanh toán

    function checkout() {
        if (cart.length === 0) {
            alert('Giỏ hàng đang trống!');
            return;
        }

        const paymentMethodId = selectedPaymentMethodId;
        if (!paymentMethodId) {
            alert('Vui lòng chọn phương thức thanh toán.');
            return;
        }

        const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
        const usedPoints = parseInt(document.getElementById('use-points')?.value || 0, 10);
        const finalAmount = Math.max(total - Math.min(usedPoints, maxPoints), 0);
        let amountTendered = finalAmount;
        if (paymentMethodId === 1) {
            amountTendered = parseFloat(document.getElementById('amount-tendered')?.value || 0, 10) || 0;
            if (amountTendered < finalAmount) {
                alert('Tiền khách đưa không đủ. Thành tiền: ' + formatMoney(finalAmount));
                return;
            }
        }

        const orderData = {
            storeId: currentStoreId,
            userId: activeCashierId,
            customerPhone: document.getElementById('customer-phone').value,
            customerName: null,
            pointsUsed: usedPoints,
            orderType: document.querySelector('input[name="orderType"]:checked').value,
            paymentMethodId: paymentMethodId,
            amountTendered: amountTendered,
            orderItems: cart.map(item => ({
                menuItemId: item.id,
                quantity: item.quantity,
                unitPrice: item.price,
                note: item.note || null
            }))
        };

        fetch('/Pos/CreateOrder', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(orderData)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Hiển thị Popup Đặt Hàng Thành Công
                const msgEl = document.getElementById('success-queue-number');
                if (msgEl) msgEl.textContent = data.queueNumber;
                
                const box = document.getElementById('order-success-box');
                if (box) {
                    box.classList.remove('d-none');
                    box.classList.add('d-flex');
                }
                
                resetAfterOrder();
            } else {
                alert('❌ Lỗi: ' + data.message);
            }
        })
        .catch(error => {
            alert('❌ Lỗi kết nối: ' + error.message);
        });
    }


    // 7. Hàm tiện ích

    function formatMoney(amount) {
        return amount.toLocaleString('vi-VN') + ' ₫';
    }

    // 8. Logic Khách Hàng (SĐT & Điểm)
    function checkCustomerPhone() {
        const phone = document.getElementById('customer-phone').value;
        const infoBox = document.getElementById('customer-info-box');
        const notFoundText = document.getElementById('customer-not-found');

        if (phone.length === 10) {
            // Đủ 10 số -> Fetch gọi C# Customer API
            fetch('/Pos/GetCustomerInfo?phone=' + phone)
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    // Khách hàng cũ
                    infoBox.classList.remove('d-none');
                    notFoundText.classList.add('d-none');
                    document.getElementById('customer-info').textContent = data.name;
                    document.getElementById('customer-points').textContent = formatMoney(data.points);
                    
                    maxPoints = data.points;
                    document.getElementById('use-points').value = 0; // Reset điểm sử dụng
                    updateTotal(); // Tính lại
                } else {
                    // Khách hàng mới
                    infoBox.classList.add('d-none');
                    notFoundText.classList.remove('d-none');
                    notFoundText.textContent = "Khách hàng mới (Sẽ đổi điểm sau khi thanh toán)";
                    notFoundText.style.color = "#d4a373";
                    maxPoints = 0;
                    updateTotal();
                }
            });
        } else {
            // Ẩn hộp điểm
            infoBox.classList.add('d-none');
            notFoundText.classList.remove('d-none');
            notFoundText.textContent = "Nhập đủ 10 số để tìm khách hàng";
            notFoundText.style.color = "";
            maxPoints = 0;
            updateTotal();
        }
    }

    // 9. Logic PIN Code Thu Ngân (biến currentPin, activeCashierId, ... đã khai báo ở đầu script)

    function addPin(num) {
        if(currentPin.length < 6) {
            currentPin += num;
            document.getElementById('pin-input').value = currentPin;
            document.getElementById('pin-error').classList.add('d-none');
        }
    }
    
    function clearPin() {
        currentPin = "";
        document.getElementById('pin-input').value = currentPin;
    }

